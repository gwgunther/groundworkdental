---
import '../styles/global.css';
import { site } from '../config/site';

interface Props {
  title: string;
  showSignOut?: boolean;
}

const { title, showSignOut = true } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — {site.name}</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-brand-cream min-h-screen">
    <!-- Minimal top bar -->
    <header class="bg-white border-b border-border-light">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between">
        <a href="/intake" class="font-serif text-lg text-charcoal">
          Groundwork <span class="text-brand-warm">Dental</span>
        </a>
        {showSignOut && (
          <button
            id="sign-out-btn"
            class="font-sans text-xs uppercase tracking-widest text-mid-gray hover:text-charcoal transition-colors"
          >
            Sign Out
          </button>
        )}
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
      <slot />
    </main>

    <footer class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6 border-t border-border-light">
      <p class="font-sans text-xs text-mid-gray">
        Questions? Email <a href={`mailto:${site.email}`} class="text-brand-warm hover:text-brand-warm-dark">{site.email}</a>
      </p>
    </footer>

    {showSignOut && (
      <script>
        document.getElementById('sign-out-btn')?.addEventListener('click', async () => {
          // Clear cookies by calling the logout endpoint
          await fetch('/intake/login?action=signout', { method: 'POST' });
          window.location.href = '/intake/login';
        });
      </script>
    )}
  </body>
</html>
