---
import { site } from '../config/site';

const currentYear = new Date().getFullYear();
---

<footer class="bg-charcoal text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      <!-- Brand -->
      <div>
        <span class="flex items-center gap-2.5 mb-4">
          <span class="font-serif text-xl text-white">Groundwork</span>
          <span class="w-px h-4 bg-neutral-600"></span>
          <span class="font-sans text-[10px] uppercase tracking-[0.2em] text-brand-sage">dental</span>
        </span>
        <p class="text-neutral-200 font-sans text-xs leading-relaxed mb-4">
          Custom dental websites built in days. You own the code, the hosting, and every account.
        </p>
        <a href={`mailto:${site.email}`} class="text-neutral-300 font-sans text-xs hover:text-white transition-colors">
          {site.email}
        </a>
      </div>

      <!-- Pages -->
      <div>
        <h3 class="font-sans text-eyebrow uppercase text-neutral-300 mb-5">Pages</h3>
        <ul class="space-y-2.5 font-sans text-xs">
          <li><a href="/how-it-works" class="text-neutral-200 hover:text-white transition-colors">How It Works</a></li>
          <li><a href="/example" class="text-neutral-200 hover:text-white transition-colors">Example Website</a></li>
          <li><a href="/pricing" class="text-neutral-200 hover:text-white transition-colors">Pricing</a></li>
          <li><a href="/compare" class="text-neutral-200 hover:text-white transition-colors">Compare Options</a></li>
          <li><a href="/about" class="text-neutral-200 hover:text-white transition-colors">About</a></li>
          <li><a href="/dental-seo-foundation" class="text-neutral-200 hover:text-white transition-colors">Dental SEO Guide</a></li>
          <li><a href="/blog" class="text-neutral-200 hover:text-white transition-colors">Resources</a></li>
        </ul>
      </div>

      <!-- CTA -->
      <div>
        <h3 class="font-sans text-eyebrow uppercase text-neutral-300 mb-5">Get Started</h3>
        <p class="text-neutral-200 font-serif text-sm mb-6 leading-relaxed">
          $2,000 flat. Your only cost after that is ~$12/year for your domain. That's it.
        </p>
        <a href="/get-started" class="btn-primary px-5 py-2.5">
          Get Started
        </a>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-neutral-800">
      <p class="font-sans text-xs text-neutral-300">&copy; {currentYear} Groundwork Dental.</p>
    </div>
  </div>
</footer>
