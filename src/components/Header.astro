---
import { navMain } from '../config/navigation';
const pathname = Astro.url.pathname;
---

<header class="bg-white border-b border-border-light sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14 md:h-16">
      <!-- Wordmark -->
      <a href="/" class="flex-shrink-0">
        <span class="flex items-center gap-2.5">
          <span class="font-serif text-xl text-charcoal">Groundwork</span>
          <span class="w-px h-4 bg-neutral-300"></span>
          <span class="font-sans text-[10px] uppercase tracking-[0.2em] text-brand-sage">dental</span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-7" aria-label="Main">
        {navMain.map((entry) => {
          const isActive = pathname === entry.href || (entry.dropdown?.some(l => pathname === l.href));
          return entry.dropdown ? (
            <div class="relative group">
              <a
                href={entry.href}
                class={`nav-link inline-flex items-center gap-1 ${isActive ? 'text-charcoal underline underline-offset-4 decoration-brand-warm decoration-1' : ''}`}
                aria-current={pathname === entry.href ? 'page' : undefined}
              >
                {entry.label}
                <svg
                  class="w-3 h-3 shrink-0 opacity-70 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              <div
                class="absolute left-0 top-full z-50 pt-2 min-w-[12rem] opacity-0 invisible translate-y-0.5 transition-all duration-150 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 group-focus-within:opacity-100 group-focus-within:visible group-focus-within:translate-y-0"
              >
                <div class="rounded border bg-white border-border-light shadow-lg py-1">
                  {entry.dropdown.map((link) => (
                    <a
                      href={link.href}
                      aria-current={pathname === link.href ? 'page' : undefined}
                      class={`block px-4 py-2.5 font-sans text-xs uppercase tracking-widest font-medium transition-colors ${pathname === link.href ? 'text-charcoal bg-surface-2' : 'text-mid-gray hover:text-charcoal hover:bg-surface-2'}`}
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={entry.href}
              aria-current={pathname === entry.href ? 'page' : undefined}
              class={`nav-link ${isActive ? 'text-charcoal underline underline-offset-4 decoration-brand-warm decoration-1' : ''}`}
            >
              {entry.label}
            </a>
          );
        })}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center">
        <a href="/get-started" class="btn-primary px-5 py-2">
          Get Started
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        class="text-mid-gray p-3 hover:text-charcoal transition-colors lg:hidden min-w-[44px] min-h-[44px] flex items-center justify-center"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="hamburger-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-border-light">
    <div class="px-4 py-4 space-y-1">
      {navMain.map((entry) => {
        const isActive = pathname === entry.href || (entry.dropdown?.some(l => pathname === l.href));
        return (
          <>
            <a
              href={entry.href}
              aria-current={pathname === entry.href ? 'page' : undefined}
              class={`block font-sans text-xs uppercase tracking-widest py-3 min-h-[44px] flex items-center hover:text-charcoal transition-colors ${isActive ? 'text-charcoal' : 'text-mid-gray'}`}
            >
              {entry.label}
            </a>
            {entry.dropdown?.map((link) => (
              <a
                href={link.href}
                aria-current={pathname === link.href ? 'page' : undefined}
                class={`block pl-4 font-sans text-xs uppercase tracking-widest py-3 min-h-[44px] flex items-center hover:text-charcoal transition-colors ${pathname === link.href ? 'text-charcoal' : 'text-neutral-400'}`}
              >
                {link.label}
              </a>
            ))}
          </>
        );
      })}
      <div class="pt-4 border-t border-border-light">
        <a href="/get-started" class="block text-center btn-primary">
          Get Started
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    hamburger?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
