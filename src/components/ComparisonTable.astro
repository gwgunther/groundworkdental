---
interface Row {
  feature: string;
  wix?: string;
  squarespace?: string;
  diy?: string;
  traditional: string;
  groundwork: string;
}

interface Props {
  rows: Row[];
  heading?: string;
}

const {
  rows,
  heading = 'Why Groundwork Dental Is Different',
} = Astro.props;

const hasFourColumns = rows.some((row) => row.wix !== undefined && row.squarespace !== undefined);
const hasThreeColumns = !hasFourColumns && rows.some((row) => row.diy !== undefined);
---

<section class="py-8">
  {heading && <h2 class="section-subheading text-center mb-10">{heading}</h2>}

  <div class="overflow-x-auto">
    <table class={`w-full text-left border-collapse mx-auto ${hasFourColumns ? 'max-w-6xl' : hasThreeColumns ? 'max-w-5xl' : 'max-w-4xl'}`}>
      <thead>
        <tr class="border-b border-border-light">
          <th class="py-3 pr-4 font-sans text-eyebrow uppercase text-neutral-400">Feature</th>
          {hasFourColumns && (
            <th class="py-3 px-4 font-sans text-eyebrow uppercase text-neutral-400">Wix (Free)</th>
          )}
          {hasFourColumns && (
            <th class="py-3 px-4 font-sans text-eyebrow uppercase text-neutral-400">Squarespace</th>
          )}
          {hasThreeColumns && (
            <th class="py-3 px-4 font-sans text-eyebrow uppercase text-neutral-400">Website Builder<span class="block normal-case font-normal text-[10px] tracking-normal text-neutral-400 mt-0.5">e.g. Wix, Squarespace</span></th>
          )}
          <th class="py-3 px-4 font-sans text-eyebrow uppercase text-neutral-400">Traditional Agency</th>
          <th class="py-3 pl-4 font-sans text-eyebrow uppercase text-brand-warm">Groundwork</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr class="border-b border-border-light">
            <td class="py-3.5 pr-4 font-serif text-charcoal text-sm font-medium">{row.feature}</td>
            {hasFourColumns && (
              <td class="py-3.5 px-4 font-serif text-mid-gray text-sm">{row.wix}</td>
            )}
            {hasFourColumns && (
              <td class="py-3.5 px-4 font-serif text-mid-gray text-sm">{row.squarespace}</td>
            )}
            {hasThreeColumns && (
              <td class="py-3.5 px-4 font-serif text-mid-gray text-sm">{row.diy}</td>
            )}
            <td class="py-3.5 px-4 font-serif text-mid-gray text-sm">{row.traditional}</td>
            <td class="py-3.5 pl-4 font-serif text-charcoal text-sm font-medium">{row.groundwork}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
