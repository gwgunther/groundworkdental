---
interface Row {
  feature: string;
  wix?: string;
  squarespace?: string;
  diy?: string;
  traditional: string;
  groundwork: string;
}

interface Props {
  rows: Row[];
  heading?: string;
}

const {
  rows,
  heading = 'Why Groundwork Dental Is Different',
} = Astro.props;

const hasFourColumns = rows.some((row) => row.wix !== undefined && row.squarespace !== undefined);
const hasThreeColumns = !hasFourColumns && rows.some((row) => row.diy !== undefined);
const columnCount = hasFourColumns ? 5 : hasThreeColumns ? 4 : 3;

const featureHead = 'py-3 px-5 font-sans text-eyebrow uppercase text-mid-gray text-left';
const dataHead = 'py-3 px-5 font-sans text-eyebrow uppercase text-mid-gray text-center';
const cell = 'py-3.5 px-5 font-serif text-mid-gray text-sm text-center';
const featureCell = 'py-3.5 px-5 font-serif text-charcoal text-sm font-bold text-left';
const groundworkHead = 'py-3 px-5 font-sans text-eyebrow uppercase text-sage-dark bg-sage-tint text-center';
const groundworkCell = 'py-3.5 px-5 font-serif text-charcoal text-sm font-medium bg-sage-tint text-center';
---

<section class="py-8">
  {heading && <h2 class="section-subheading text-center mb-10">{heading}</h2>}

  <div class="overflow-x-auto -mx-4 px-4 sm:mx-0 sm:px-0">
    <table class="w-full table-fixed border-collapse">
      <colgroup>
        {Array.from({ length: columnCount }).map((_, i) => (
          <col style={`width: ${100 / columnCount}%`} />
        ))}
      </colgroup>
      <thead>
        <tr class="border-b border-border-light">
          <th scope="col" class={featureHead}>Feature</th>
          {hasFourColumns && (
            <th scope="col" class={dataHead}>Wix (Free)</th>
          )}
          {hasFourColumns && (
            <th scope="col" class={dataHead}>Squarespace</th>
          )}
          {hasThreeColumns && (
            <th scope="col" class={dataHead}>DIY<span class="block normal-case font-normal text-[10px] tracking-normal text-mid-gray mt-0.5">Wix, Squarespace, etc.</span></th>
          )}
          <th scope="col" class={dataHead}>Traditional Agency</th>
          <th scope="col" class={groundworkHead}>Groundwork</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr class="border-b border-border-light">
            <td scope="row" class={featureCell}>{row.feature}</td>
            {hasFourColumns && (
              <td class={cell}>{row.wix}</td>
            )}
            {hasFourColumns && (
              <td class={cell}>{row.squarespace}</td>
            )}
            {hasThreeColumns && (
              <td class={cell}>{row.diy}</td>
            )}
            <td class={cell}>{row.traditional}</td>
            <td class={groundworkCell}>{row.groundwork}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
