---
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
  heading?: string;
}

const {
  faqs,
  heading = 'Frequently Asked Questions',
} = Astro.props;
---

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': faqs.map(faq => ({
    '@type': 'Question',
    'name': faq.question,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': faq.answer,
    },
  })),
})} />

<section class="py-12">
  <h2 class="section-subheading text-center mb-10">{heading}</h2>

  <div class="max-w-3xl mx-auto divide-y divide-border-light border-t border-border-light">
    {faqs.map((faq, index) => (
      <div>
        <button
          class="w-full text-left py-5 flex justify-between items-start bg-transparent hover:text-brand-warm transition-colors duration-200"
          aria-expanded="false"
          aria-controls={`faq-content-${index}`}
          data-faq-btn={index}
        >
          <span class="font-serif text-charcoal pr-6">{faq.question}</span>
          <svg
            class="w-4 h-4 text-neutral-400 flex-shrink-0 mt-1.5 transition-transform duration-200"
            data-faq-icon={index}
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div
          id={`faq-content-${index}`}
          class="faq-panel grid"
          style="grid-template-rows: 0fr;"
          data-faq-content={index}
        >
          <div class="overflow-hidden">
            <p class="pb-5 text-mid-gray font-serif text-sm leading-relaxed">{faq.answer}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .faq-panel {
    transition: grid-template-rows 220ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .faq-panel.open {
    grid-template-rows: 1fr;
  }
  @media (prefers-reduced-motion: reduce) {
    .faq-panel {
      transition: none;
    }
  }
</style>

<script>
  const buttons = document.querySelectorAll('[data-faq-btn]');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const index = btn.getAttribute('data-faq-btn');
      const panel = document.querySelector(`[data-faq-content="${index}"]`);
      const icon = document.querySelector(`[data-faq-icon="${index}"]`);
      const isOpen = panel?.classList.contains('open');

      panel?.classList.toggle('open', !isOpen);
      icon?.classList.toggle('rotate-180', !isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>
