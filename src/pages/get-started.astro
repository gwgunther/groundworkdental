---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';
---

<BaseLayout
  title="Get Started — Free Draft in 24 Hours | Groundwork Dental"
  description="Enter your website URL and email. We'll rebuild your dental website into a modern, search-ready version you can preview within 24 hours. If you like it, it's $2,000. If not, you owe nothing."
>
  <!-- Hero -->
  <section class="bg-brand-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="max-w-2xl mx-auto text-center">
        <h1 class="section-heading mb-6">See Your Practice Reimagined.</h1>
        <p class="font-serif text-xl text-mid-gray leading-relaxed">
          Enter your website URL. We'll rebuild it into a modern, search-ready version you can preview within 24 hours. If you like it, it's $2,000. If you don't, you owe nothing.
        </p>
      </div>
    </div>
  </section>

  <!-- Form -->
  <section class="py-16">
    <div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8">
      <form id="get-started-form" class="space-y-6">
        <div>
          <label for="website" class="block font-sans text-xs uppercase tracking-widest text-mid-gray mb-2">
            Your Current Website URL
          </label>
          <input
            type="url"
            id="website"
            name="website"
            required
            placeholder="https://yourdentalpractice.com"
            class="w-full px-4 py-3 border border-border-light rounded font-serif text-charcoal placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-brand-warm focus:border-transparent"
          />
        </div>

        <div>
          <label for="email" class="block font-sans text-xs uppercase tracking-widest text-mid-gray mb-2">
            Your Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="doctor@yourpractice.com"
            class="w-full px-4 py-3 border border-border-light rounded font-serif text-charcoal placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-brand-warm focus:border-transparent"
          />
        </div>

        <div>
          <label for="name" class="block font-sans text-xs uppercase tracking-widest text-mid-gray mb-2">
            Practice Name <span class="text-neutral-400">(optional)</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder="Smith Family Dental"
            class="w-full px-4 py-3 border border-border-light rounded font-serif text-charcoal placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-brand-warm focus:border-transparent"
          />
        </div>

        <button
          type="submit"
          class="w-full btn-primary py-3.5 text-center"
        >
          Build My Draft
        </button>

        <p class="text-center font-serif text-sm text-mid-gray">
          No payment required. No obligation. We build it, you preview it, you decide.
        </p>
      </form>

      <!-- Success State -->
      <div id="form-success" class="hidden text-center py-12">
        <div class="w-16 h-16 rounded-full bg-sage/20 flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 class="font-serif text-2xl text-charcoal mb-4">We're on it.</h2>
        <p class="font-serif text-mid-gray leading-relaxed mb-2">
          You'll receive a preview link at your email within 24 hours.
        </p>
        <p class="font-serif text-sm text-mid-gray">
          Click around, test it on your phone, show your team. No pressure.
        </p>
      </div>

      <!-- Error State -->
      <div id="form-error" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded text-center">
        <p class="font-serif text-sm text-red-700">
          Something went wrong. Please email us directly at <a href={`mailto:${site.email}`} class="underline">{site.email}</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="py-12 bg-surface-2">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
        <div>
          <p class="font-serif text-charcoal font-semibold mb-1">No payment upfront</p>
          <p class="font-serif text-sm text-mid-gray">You see the finished work before spending a cent.</p>
        </div>
        <div>
          <p class="font-serif text-charcoal font-semibold mb-1">You own everything</p>
          <p class="font-serif text-sm text-mid-gray">Code, hosting, domain, analytics. All yours.</p>
        </div>
        <div>
          <p class="font-serif text-charcoal font-semibold mb-1">~$12/year after</p>
          <p class="font-serif text-sm text-mid-gray">Domain renewal. That's it. Hosting is free.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('get-started-form') as HTMLFormElement;
  const successDiv = document.getElementById('form-success');
  const errorDiv = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data = {
      website_url: formData.get('website'),
      email: formData.get('email'),
      practice_name: formData.get('name') || null,
      submitted_at: new Date().toISOString(),
      status: 'pending',
    };

    // Submit to Supabase REST API
    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    if (!supabaseUrl || !supabaseAnonKey) {
      // Fallback: mailto if Supabase isn't configured yet
      const subject = encodeURIComponent('New Website Draft Request');
      const body = encodeURIComponent(
        `Website: ${data.website_url}\nEmail: ${data.email}\nPractice: ${data.practice_name || 'Not provided'}`
      );
      window.location.href = `mailto:garrett@groundworkdental.com?subject=${subject}&body=${body}`;
      return;
    }

    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/leads`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': supabaseAnonKey,
          'Authorization': `Bearer ${supabaseAnonKey}`,
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify(data),
      });

      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      // Show success, hide form
      form.classList.add('hidden');
      successDiv?.classList.remove('hidden');
    } catch (err) {
      console.error('Form submission failed:', err);
      errorDiv?.classList.remove('hidden');
    }
  });
</script>
