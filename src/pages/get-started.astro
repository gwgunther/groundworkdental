---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';
---

<BaseLayout
  title="Get Started — Free Draft in 24 Hours | Groundwork Dental"
  description="Tell us about your practice. We'll build a modern, search-ready version of your website you can preview within 24 hours. If you like it, it's $2,000. If not, you owe nothing."
>
  <!-- Hero -->
  <section class="bg-brand-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="max-w-2xl mx-auto text-center">
        <h1 class="section-heading mb-6">See Your Practice Reimagined.</h1>
        <p class="font-serif text-xl text-mid-gray leading-relaxed">
          Tell us a little about your practice. We'll build a modern, search-ready version of your website you can preview within 24 hours. If you like it, it's $2,000. If you don't, you owe nothing.
        </p>
      </div>
    </div>
  </section>

  <!-- Form -->
  <section class="py-16">
    <div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8">
      <form id="get-started-form" class="space-y-6">
        <div>
          <label for="name" class="block font-sans text-xs uppercase tracking-widest text-mid-gray mb-2">
            Your Name
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="Dr. Sarah Smith"
            class="w-full px-4 py-3 border border-border-light rounded font-serif text-charcoal placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-brand-warm focus:border-transparent"
          />
        </div>

        <div>
          <label for="email" class="block font-sans text-xs uppercase tracking-widest text-mid-gray mb-2">
            Your Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="doctor@yourpractice.com"
            class="w-full px-4 py-3 border border-border-light rounded font-serif text-charcoal placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-brand-warm focus:border-transparent"
          />
        </div>

        <div>
          <label for="website" class="block font-sans text-xs uppercase tracking-widest text-mid-gray mb-2">
            Current Website URL <span class="text-neutral-400">(if you have one)</span>
          </label>
          <input
            type="url"
            id="website"
            name="website"
            placeholder="https://yourdentalpractice.com"
            class="w-full px-4 py-3 border border-border-light rounded font-serif text-charcoal placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-brand-warm focus:border-transparent"
          />
        </div>

        <div>
          <label for="comment" class="block font-sans text-xs uppercase tracking-widest text-mid-gray mb-2">
            Anything else we should know? <span class="text-neutral-400">(optional)</span>
          </label>
          <textarea
            id="comment"
            name="comment"
            rows="4"
            placeholder="Tell us about your practice, what services you offer, or what you're looking for in a website..."
            class="w-full px-4 py-3 border border-border-light rounded font-serif text-charcoal placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-brand-warm focus:border-transparent resize-y"
          ></textarea>
        </div>

        <button
          type="submit"
          id="submit-btn"
          class="w-full btn-primary py-3.5 text-center"
        >
          Build My Draft
        </button>

        <p class="text-center font-serif text-sm text-mid-gray">
          No payment required. No obligation. We build it, you preview it, you decide.
        </p>
      </form>

      <!-- Success State -->
      <div id="form-success" class="hidden text-center py-12">
        <div class="w-16 h-16 rounded-full bg-sage/20 flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 class="font-serif text-2xl text-charcoal mb-4">We're on it.</h2>
        <p class="font-serif text-mid-gray leading-relaxed mb-2">
          You'll hear from us within 24 hours with a preview of your new site.
        </p>
        <p class="font-serif text-sm text-mid-gray">
          Click around, test it on your phone, show your team. No pressure.
        </p>
      </div>

      <!-- Error State -->
      <div id="form-error" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded text-center">
        <p class="font-serif text-sm text-red-700">
          Something went wrong. Please email us directly at <a href={`mailto:${site.email}`} class="underline">{site.email}</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="py-12 bg-surface-2">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
        <div>
          <p class="font-serif text-charcoal font-semibold mb-1">No payment upfront</p>
          <p class="font-serif text-sm text-mid-gray">You see the finished work before spending a cent.</p>
        </div>
        <div>
          <p class="font-serif text-charcoal font-semibold mb-1">You own everything</p>
          <p class="font-serif text-sm text-mid-gray">Code, hosting, domain, analytics. All yours.</p>
        </div>
        <div>
          <p class="font-serif text-charcoal font-semibold mb-1">~$12/year after</p>
          <p class="font-serif text-sm text-mid-gray">Domain renewal paid to your registrar — not us. Hosting is free.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('get-started-form') as HTMLFormElement;
  const successDiv = document.getElementById('form-success');
  const errorDiv = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Disable button and show loading state
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    errorDiv?.classList.add('hidden');

    const formData = new FormData(form);
    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      website: formData.get('website') || '',
      comment: formData.get('comment') || '',
    };

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      // Show success, hide form
      form.classList.add('hidden');
      successDiv?.classList.remove('hidden');
    } catch (err) {
      console.error('Form submission failed:', err);
      errorDiv?.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Build My Draft';
    }
  });
</script>
