---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import FAQBlock from '../components/FAQBlock.astro';
import CTABlock from '../components/CTABlock.astro';
import { site } from '../config/site';

const comparisonRows = [
  { feature: 'Setup Cost', traditional: '$2,000–$15,000', groundwork: '$2,000 flat' },
  { feature: 'Monthly Fee', traditional: '$200–$500/mo required', groundwork: '$0 (self-host) or $100/mo managed' },
  { feature: 'Ongoing Cost', traditional: '$2,400–$6,000/year', groundwork: '~$12/year (domain only)' },
  { feature: 'Templates', traditional: 'Shared across hundreds of clients', groundwork: '100% custom per practice' },
  { feature: 'Ownership', traditional: 'Agency controls hosting & domain', groundwork: 'You own everything' },
  { feature: 'Lock-in', traditional: 'Site disappears if you leave', groundwork: 'None — full transferability' },
  { feature: 'PageSpeed', traditional: '40–70 (WordPress/Wix)', groundwork: '90+ (static HTML, zero JS)' },
  { feature: 'SEO', traditional: 'Basic meta tags', groundwork: 'Structured data on every page — optimized for Google and AI search tools' },
  { feature: 'Build Time', traditional: '6–12 weeks', groundwork: '3–7 business days' },
  { feature: 'Vendor Switching', traditional: 'Weeks of migration, content loss', groundwork: 'Hand the GitHub URL to any developer' },
];

const faqs = [
  {
    question: 'What do I actually own after the build?',
    answer: 'Everything. Your domain, your content, your hosting account, your code repository, and your Google accounts (Analytics, Search Console, Business Profile). If you never hear from us again, everything keeps working.',
  },
  {
    question: 'What\'s the catch with the $2,000 price?',
    answer: 'No catch. That\'s just the minimum cost to have a properly built website. Domain renewal is ~$12/year paid to your registrar — not to us. Hosting on Cloudflare Pages is free. There is no monthly fee. If you want us to manage things for you, that\'s $100/month — but it\'s priced that way intentionally so you\'re motivated to just host it yourself and save the money.',
  },
  {
    question: 'Do you use AI to build the websites?',
    answer: 'Yes. The page you\'re looking at right now was also built with the help of AI — doesn\'t it look good? Here\'s the thing: you or your tech-savvy niece could also build a website with AI tools. But there\'s still a lot that goes on in the background — writing SEO content, setting up hosting, configuring structured data, submitting sitemaps — that ChatGPT can\'t quite handle on its own yet. I could teach you all that, but it would cost more than $2,000 and take longer than 7 days. Which is what I\'m offering.',
  },
  {
    question: 'What happens if I stop working with you?',
    answer: 'Nothing changes. That\'s the whole point. Our explicit goal is that you never have to reach back out. No follow-ups, no check-ins, no renewal notices. Your website keeps running on its own. If you ever want to make updates or get interested in more aggressive growth, we\'re here — but it\'s entirely your call.',
  },
  {
    question: 'Will this actually help me get more patients?',
    answer: 'There\'s a saying: "Nice shoes won\'t get you the girl, but bad shoes will lose her." Same thing here. A great website alone won\'t flood your practice with new patients — but a bad one (or no website at all) is actively turning people away. We don\'t promise growth. That\'s a different beast entirely. Our focus is the baseline foundation — the groundwork. You\'ll be set up extremely well for SEO and AI search with authoritative, geographic content. But the basics are really just an optimized Google Business Profile and a professional, accurate website. Real growth requires regular content creation — yes, more articles, yes, even TikToks. Let\'s crawl before we walk.',
  },
  {
    question: 'I already use a service like Tebra for my practice. How is this different?',
    answer: 'Those platforms are full-service practice management systems — patient scheduling, EHR, billing, the works. That\'s a different product solving a different problem. Groundwork isn\'t a practice management tool. It\'s just a website. A really good one that you own outright. Pay once, get your site, done. If you eventually want full-service patient management, you can still use those tools — this complements that journey. But most practices don\'t need all that to start. They just need to look professional online and show up in search results.',
  },
];
---

<BaseLayout
  title="Groundwork Dental — Dental Websites Without Agency Lock-In"
  description="Custom SEO-ready dental websites built in days. You own the code, the hosting, and every account. $2,000 flat. No lock-in."
>
  <!-- Hero -->
  <section class="bg-brand-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">Dental websites, reimagined</p>
        <h1 class="font-serif text-5xl md:text-6xl font-normal leading-tight tracking-tight text-charcoal mb-6">
          Dental Websites Without Agency Lock-In.
        </h1>
        <p class="font-serif text-xl text-mid-gray leading-relaxed mb-8 max-w-2xl">
          Custom SEO-ready dental sites built in days. You own the code, the hosting, and every account. No templates. No monthly traps. No fine print.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/get-started" class="btn-primary px-8 py-3.5">
            Get Started
          </a>
          <a href="/example" class="btn-secondary px-8 py-3.5">
            See an Example
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- The $12/year Number -->
  <section class="py-10 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="eyebrow text-brand-warm mb-4">After the build</p>
      <p class="text-6xl md:text-8xl text-charcoal mb-4 font-mono tracking-tight">~$12<span class="text-mid-gray text-3xl md:text-4xl">/year</span></p>
      <p class="font-serif text-mid-gray text-lg max-w-xl mx-auto leading-relaxed">
        That's your domain renewal. Hosting is free. No WordPress subscription. No Wix plan. No monthly "hosting fee" that's really just an agency keeping your site on their server so they can turn it off if you leave.
      </p>
    </div>
  </section>

  <!-- What You Get -->
  <section class="py-10 bg-surface-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="section-subheading mb-4">Everything Included. Nothing Hidden.</h2>
        <p class="font-serif text-mid-gray max-w-2xl mx-auto">One price. Every deliverable listed. No "Phase 2" upsell. No "oh, hosting is extra."</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <FeatureCard
          title="30–50+ Custom Pages"
          description="Homepage, about, service hubs, blog, gallery, FAQ, financing, location pages. Links to your existing booking system. All unique to your practice."
        />
        <FeatureCard
          title="90+ PageSpeed Score"
          description="Static HTML, zero JavaScript by default. Your site loads instantly on any device. No bloated WordPress plugins slowing things down."
        />
        <FeatureCard
          title="Google & AI Search Ready"
          description="Structured data on every page tells Google and AI tools (ChatGPT, Perplexity, Google AI Overviews) exactly what you do, where you are, and who your doctors are."
        />
        <FeatureCard
          title="Full SEO Foundation"
          description="Keyword-optimized titles, heading hierarchy, internal linking, XML sitemap, robots.txt, Open Graph cards. The entire baseline, done right."
        />
        <FeatureCard
          title="Google Business Profile"
          description="Full profile optimization — categories, services, photos, and settings configured correctly. The single most important ranking factor for local search."
        />
        <FeatureCard
          title="You Own Everything"
          description="GitHub repo, Cloudflare hosting, domain, analytics, search console. Fire us tomorrow — your website keeps working. No kill switch."
        />
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <ComparisonTable rows={comparisonRows} heading="Traditional Agency vs. Groundwork Dental" />
    </div>
  </section>

  <!-- AI Search -->
  <section class="py-10 bg-surface-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow text-brand-warm mb-4">Beyond Google</p>
        <h2 class="section-subheading mb-4">Show Up When Patients Ask AI</h2>
        <p class="font-serif text-mid-gray leading-relaxed mb-6">
          Patients are asking ChatGPT, Perplexity, and Google AI Overviews for dentist recommendations. These tools pull answers from websites with structured data and authoritative content — exactly what we build into every page. If your website gives AI nothing to work with, you're invisible in the fastest-growing search channel.
        </p>
        <a href="/how-it-works" class="font-sans text-sm text-brand-warm font-medium hover:text-brand-warm-dark transition-colors">
          Learn how it works &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- The Ownership Guarantee -->
  <section class="py-10 bg-charcoal text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <p class="font-sans text-eyebrow uppercase text-neutral-500 mb-4">The guarantee</p>
        <h2 class="font-serif text-3xl md:text-4xl font-normal mb-6">The Ownership Guarantee</h2>
        <p class="font-serif text-lg text-neutral-300 leading-relaxed mb-6">
          After the project's done, you could hand the whole thing off to your tech-savvy niece and let her vibe-code it from there. Seriously. She'll understand what that means, even if you don't.
        </p>
        <p class="font-serif text-neutral-400 leading-relaxed mb-8">
          The point is: it's yours. Fire us tomorrow, hire someone else, or never talk to us again. Your website keeps working. No kill switch. No hostage negotiation.
        </p>
        <p class="font-sans text-xs text-neutral-500">
          You keep: the domain, the hosting, the website code, the design assets, the SEO content, all Google accounts, all analytics. We walk away clean.
        </p>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-subheading text-center mb-12">How It Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-10 h-10 rounded border border-border-light text-charcoal font-mono text-sm flex items-center justify-center mx-auto mb-4">01</div>
          <h3 class="font-serif text-charcoal mb-2">We Rebuild Your Site</h3>
          <p class="font-serif text-mid-gray text-sm leading-relaxed">Give us your current website URL. We'll create a modern, search-ready version you can preview live before committing.</p>
        </div>
        <div class="text-center">
          <div class="w-10 h-10 rounded border border-border-light text-charcoal font-mono text-sm flex items-center justify-center mx-auto mb-4">02</div>
          <h3 class="font-serif text-charcoal mb-2">You Review It</h3>
          <p class="font-serif text-mid-gray text-sm leading-relaxed">Click around. Check your phone. Read the content. Send us one round of feedback and we'll dial it in.</p>
        </div>
        <div class="text-center">
          <div class="w-10 h-10 rounded border border-border-light text-charcoal font-mono text-sm flex items-center justify-center mx-auto mb-4">03</div>
          <h3 class="font-serif text-charcoal mb-2">You Own It Forever</h3>
          <p class="font-serif text-mid-gray text-sm leading-relaxed">We transfer everything to your accounts. Your code, your hosting, your domain. Done. ~$12/year to keep it running.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why This Exists -->
  <section class="py-10 bg-surface-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow text-brand-warm mb-4">Why this exists</p>
        <h2 class="section-subheading mb-4">Dentists Deserve Better Websites</h2>
        <p class="font-serif text-mid-gray leading-relaxed mb-6">
          You went to school to fix teeth, not to navigate hosting providers and SEO plugins. But somehow your online presence has become one more thing you're expected to figure out — or overpay someone else to handle. Most dentists don't need anything crazy. Just a professional site that actually shows up when someone searches for a dentist nearby. That shouldn't cost $15,000 or require a monthly ransom.
        </p>
        <a href="/about" class="font-sans text-sm text-brand-warm font-medium hover:text-brand-warm-dark transition-colors">
          Learn more &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock variant="dark" />
    </div>
  </section>
</BaseLayout>
