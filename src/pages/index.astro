---
import BaseLayout from '../layouts/BaseLayout.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import FAQBlock from '../components/FAQBlock.astro';
import CTABlock from '../components/CTABlock.astro';
import { site } from '../config/site';

const comparisonRows = [
  { feature: 'Setup cost', diy: 'Free', traditional: '$2,000–$15,000', groundwork: '$2,000 flat' },
  { feature: 'Yearly cost', diy: '$0–$200/yr', traditional: '$2,400+/yr ($200+/mo)', groundwork: '~$12/yr (domain only)' },
  { feature: 'Design', diy: 'Shared templates', traditional: 'Shared across clients', groundwork: '100% custom' },
  { feature: 'Mobile', diy: 'Responsive templates', traditional: 'Varies by agency', groundwork: 'Optimized on every device' },
  { feature: 'Speed', diy: 'Slow–moderate', traditional: 'Moderate', groundwork: '90+ PageSpeed' },
  { feature: 'SEO optimization', diy: 'Minimal', traditional: 'Varies by agency', groundwork: 'Full — built for Google + AI' },
  { feature: 'Content', diy: 'You write it', traditional: 'Written for you', groundwork: 'Written for you' },
  { feature: 'Editing interface', diy: 'Visual drag-and-drop', traditional: 'They manage it for you', groundwork: 'Open code — any developer can update it' },
  { feature: 'Ongoing updates', diy: 'You do it yourself', traditional: 'Included in monthly fee', groundwork: 'Pay as needed' },
  { feature: 'Ownership', diy: 'Hosted on their platform', traditional: 'Varies by provider', groundwork: 'You own code, hosting, domain' },
  { feature: 'Build time', diy: 'Weeks (your time)', traditional: '4–12 weeks', groundwork: '3–7 business days' },
  { feature: 'Google Business Profile', diy: 'Not included', traditional: 'Sometimes, extra cost', groundwork: 'Included' },
];

const faqs = [
  {
    question: 'What do I actually own after the build?',
    answer: 'Everything. Your domain, your content, your hosting account, your code repository, and your Google accounts (Analytics, Search Console, Business Profile). If you never hear from us again, everything keeps working.',
  },
  {
    question: 'What\'s the catch with the $2,000 price?',
    answer: 'No catch. That\'s just the minimum cost to have a properly built website. Domain renewal is ~$12/year paid to your registrar — not to us. Hosting on Cloudflare Pages is free. There is no monthly fee. If you want us to manage things for you, that\'s $100/month — but it\'s priced that way intentionally so you\'re motivated to just host it yourself and save the money.',
  },
  {
    question: 'Do you use AI to build the websites?',
    answer: 'Yes. The page you\'re looking at right now was also built with the help of AI — doesn\'t it look good? Here\'s the thing: you or your tech-savvy niece could also build a website with AI tools. But there\'s still a lot that goes on in the background — writing SEO content, setting up hosting, configuring structured data, submitting sitemaps — that ChatGPT can\'t quite handle on its own yet. We could teach you all that, but it would cost more than $2,000 and take longer than 7 days. Which is what we\'re offering.',
  },
  {
    question: 'What happens if I stop working with you?',
    answer: 'Nothing changes. That\'s the whole point. Our explicit goal is that you never have to reach back out. No follow-ups, no check-ins, no renewal notices. Your website keeps running on its own. If you ever want to make updates or get interested in more aggressive growth, we\'re here — but it\'s entirely your call.',
  },
  {
    question: 'Will this actually help me get more patients?',
    answer: 'There\'s a saying: "Nice shoes won\'t get you the girl, but bad shoes will lose her." Same thing here. A great website alone won\'t flood your practice with new patients — but a bad one (or no website at all) is actively turning people away. We don\'t promise growth. That\'s a different beast entirely. Our focus is the baseline foundation — the groundwork. You\'ll be set up extremely well for SEO and AI search with authoritative, geographic content. But the basics are really just an optimized Google Business Profile and a professional, accurate website. Real growth requires regular content creation — yes, more articles, yes, even TikToks. Let\'s crawl before we walk.',
  },
  {
    question: 'What if I need a fix or update later?',
    answer: 'Most practices don\'t need many changes after the initial build. But when you do, just pay $100 for a single month on the retainer. You get the full month to request whatever fixes you need — then it\'s done. No ongoing commitment.',
  },
  {
    question: 'I already use a service like Tebra for my practice. How is this different?',
    answer: 'Those platforms are full-service practice management systems — patient scheduling, EHR, billing, the works. That\'s a different product solving a different problem. Groundwork isn\'t a practice management tool. It\'s just a website. A really good one that you own outright. Pay once, get your site, done. If you eventually want full-service patient management, you can still use those tools — this complements that journey. But most practices don\'t need all that to start. They just need to look professional online and show up in search results.',
  },
];

const howItWorksSteps = [
  {
    title: 'Tell us about you',
    description: 'Your website URL and Google listing are enough to get started. Share as much or as little as you\'d like about your practice and goals.',
  },
  {
    title: 'We build it',
    description: 'You\'ll get a live preview in 7 days. A real site you can open on your phone — not a mockup.',
  },
  {
    title: 'You review it',
    description: '30 days to click around and send feedback. When you\'re happy, we connect your domain and the new site goes live.',
  },
  {
    title: 'You own it',
    description: 'Domain, hosting, and code — all in your name. Hire us again, hand it to any developer, or build on it yourself. No lock-in.',
  },
];

const includedFeatures = [
  {
    title: 'SEO Foundation',
    description: 'Every page set up so patients searching nearby can find you — with a page for each service you offer.',
  },
  {
    title: 'Google Business Profile + Reviews',
    description: 'Your Google listing set up with hours, services, and photos. Easy review collection — and they show on your site.',
  },
  {
    title: 'AI Search Ready',
    description: 'When someone asks ChatGPT or Google AI for a dentist nearby, your practice can appear in the answer.',
  },
  {
    title: '90+ PageSpeed Score',
    description: 'Loads in under a second on any phone. No plugins, no clutter.',
  },
];
---

<BaseLayout
  title="Groundwork Dental — Custom Dental Websites You Actually Own"
  description="Custom SEO-ready dental websites built in days. You own the code, the hosting, and every account. $2,000 flat."
>
  <!-- Hero -->
  <section class="bg-surface-2 border-b border-border-light">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">Ready in days. No monthly fees.</p>
        <h1 class="font-serif text-5xl md:text-6xl font-normal leading-tight tracking-tight text-charcoal mb-6">
          Dental Websites<br />Built <em>for</em> Dentists
        </h1>
        <p class="font-serif text-xl text-mid-gray leading-relaxed mb-8">
          SEO and AI-ready, Google Business Profile included. Get found by patients without overpaying.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/get-started" class="btn-primary px-8 py-3.5">
            Get Started
          </a>
          <a href="/example" class="btn-secondary px-8 py-3.5 !border-neutral-400 w-full sm:w-auto">
            See an Example
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Three Questions -->
  <section class="bg-white py-12 md:py-20 border-b border-border-light">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="eyebrow mb-6">Why Groundwork?</p>
        <p class="font-serif text-3xl md:text-4xl text-charcoal leading-snug mb-6">
          Not every dental practice needs a marketing agency. They just need the basics done right.
        </p>
        <p class="font-serif text-mid-gray italic mb-5">If any of these sound familiar, you're in the right place.</p>
        <ul class="space-y-3">
          {[
            'Patients aren\'t finding your practice on Google or ChatGPT',
            'You\'re tired of paying monthly website fees',
            'You want a website that brings in new patients, but don\'t have time to manage it',
            'Your website feels outdated',
            'You just want a website that works',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-4 h-4 text-sage-dark flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="font-serif text-charcoal leading-snug">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- What You Get -->
  <section class="bg-surface-2 py-12 md:py-20 border-b border-border-light">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-10">
        <p class="eyebrow text-sage-dark mb-4">What you get</p>
        <h2 class="section-subheading">One price. Everything included.</h2>
      </div>

      <div class="max-w-5xl mx-auto">
        <div class="max-w-2xl mx-auto mb-8">
          <div class="grid grid-cols-2 divide-x divide-border-light/70">
            <div class="text-center px-4 sm:px-8">
              <p class="font-mono text-4xl md:text-5xl text-charcoal leading-none">$2,000</p>
              <p class="font-sans text-xs uppercase tracking-widest text-mid-gray mt-2 mb-2">One-time build</p>
              <p class="font-serif text-sm text-mid-gray leading-snug text-pretty">Ready in a week— not&nbsp;months.</p>
              <p class="font-serif text-sm text-mid-gray leading-snug text-pretty mt-1">You own everything.</p>
            </div>
            <div class="text-center px-4 sm:px-8">
              <p class="font-mono text-4xl md:text-5xl text-charcoal leading-none">$0</p>
              <p class="font-sans text-xs uppercase tracking-widest text-mid-gray mt-2 mb-2">Per year after that</p>
              <p class="font-serif text-sm text-mid-gray leading-snug text-pretty">No ongoing fees. Free&nbsp;hosting.</p>
              <p class="font-serif text-sm text-mid-gray leading-snug text-pretty mt-1">$12/year just for your&nbsp;domain— not&nbsp;us.</p>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
          {includedFeatures.map((feature) => (
            <div class="rounded border border-border-light bg-white p-4 h-full text-center">
              <h3 class="font-serif text-base text-charcoal mb-1 leading-snug">{feature.title}</h3>
              <p class="font-serif text-sm text-mid-gray leading-snug">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="text-center">
        <a href="/pricing" class="btn-primary px-8 py-3.5">
          View Full Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <ComparisonTable rows={comparisonRows} heading="How We Compare" />
    </div>
  </section>

  <!-- The Ownership Guarantee -->
  <section class="py-10 bg-charcoal text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="eyebrow text-on-dark-muted mb-4">The guarantee</p>
        <h2 class="font-serif text-3xl md:text-4xl font-normal mb-6">You own everything</h2>
        <p class="font-serif text-lg text-on-dark leading-relaxed mb-4">
          Domain, hosting, code, and every Google account — yours from day one. Walk away anytime. Your site keeps running.
        </p>
        <p class="font-serif text-on-dark leading-relaxed mb-4">
          That's how we charge $2,000 once — not a monthly retainer.
        </p>
        <p class="font-sans text-sm text-on-dark-muted leading-relaxed">
          Managed hosting ($100/mo) is available, but we don't recommend it. Most practices don't need it. <a href="/pricing" class="text-on-dark hover:text-white transition-colors underline underline-offset-2">See pricing</a>
        </p>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-6 border-b border-border-light">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-2xl md:text-3xl text-charcoal text-center mb-4">How It Works</h2>
      <div class="max-w-2xl mx-auto border border-border-light rounded overflow-hidden bg-white">
        {howItWorksSteps.map((step, i) => (
          <div class="flex gap-3 sm:gap-4 px-4 pt-3 last:pb-3">
            <div class="flex flex-col items-center shrink-0 w-5 self-stretch">
              <span class="font-mono text-sm text-sage-dark tabular-nums leading-none bg-white relative z-[1] pt-0.5">
                {String(i + 1).padStart(2, '0')}
              </span>
              {i < howItWorksSteps.length - 1 && (
                <div class="flex flex-col items-center flex-1 py-1 min-h-4" aria-hidden="true">
                  <div class="w-px flex-1 bg-border-light/80"></div>
                  <svg class="w-2.5 h-2.5 text-border-light shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </div>
              )}
            </div>
            <div class={`min-w-0 flex-1 ${i < howItWorksSteps.length - 1 ? 'pb-3' : ''}`}>
              <h3 class="font-serif text-charcoal text-[15px] leading-snug mb-0.5">{step.title}</h3>
              <p class="font-serif text-sm text-mid-gray leading-snug">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="text-center mt-3">
        <a href="/how-it-works" class="font-sans text-xs text-sage-dark font-medium hover:text-sage-dark transition-colors">
          Full walkthrough &rarr;
        </a>
      </p>
    </div>
  </section>

  <!-- Why This Exists -->
  <section class="py-10 bg-surface-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="eyebrow text-sage-dark mb-4">Why this exists</p>
        <h2 class="section-subheading mb-4">Dentists Deserve Better Websites</h2>
        <p class="font-serif text-mid-gray leading-relaxed mb-6">
          You went to school to fix teeth, not to navigate hosting providers and SEO plugins. But somehow your online presence has become one more thing you're expected to figure out — or overpay someone else to handle. Most dentists don't need anything crazy. Just a professional site that actually shows up when someone searches for a dentist nearby. That shouldn't cost $15,000 or require a monthly subscription.
        </p>
        <a href="/about" class="btn-secondary inline-block">
          Why we built this
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock variant="dark" />
    </div>
  </section>
</BaseLayout>
