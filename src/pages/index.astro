---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import FAQBlock from '../components/FAQBlock.astro';
import CTABlock from '../components/CTABlock.astro';
import { site } from '../config/site';

const comparisonRows = [
  { feature: 'Setup cost', diy: 'Free', traditional: '$2,000–$15,000', groundwork: '$2,000 flat' },
  { feature: 'Monthly fee', diy: '$0 (with ads) or $16+/mo', traditional: '$200–$500/mo', groundwork: '$0 (hosting is free)' },
  { feature: 'Design', diy: 'Shared templates', traditional: 'Shared across clients', groundwork: '100% custom' },
  { feature: 'Speed', diy: 'Slow–moderate', traditional: 'Slow–moderate', groundwork: '90+ PageSpeed' },
  { feature: 'SEO', diy: 'Basic or none', traditional: 'Basic', groundwork: 'Full — structured for Google + AI' },
  { feature: 'Ownership', diy: 'Hosted on their platform', traditional: 'Varies by provider', groundwork: 'You own code, hosting, domain' },
  { feature: 'Build time', diy: 'Weeks (your time)', traditional: '6–12 weeks', groundwork: '3–7 business days' },
  { feature: 'Google Business Profile', diy: 'Not included', traditional: 'Sometimes, extra cost', groundwork: 'Included' },
];

const faqs = [
  {
    question: 'What do I actually own after the build?',
    answer: 'Everything. Your domain, your content, your hosting account, your code repository, and your Google accounts (Analytics, Search Console, Business Profile). If you never hear from us again, everything keeps working.',
  },
  {
    question: 'What\'s the catch with the $2,000 price?',
    answer: 'No catch. That\'s just the minimum cost to have a properly built website. Domain renewal is ~$12/year paid to your registrar — not to us. Hosting on Cloudflare Pages is free. There is no monthly fee. If you want us to manage things for you, that\'s $100/month — but it\'s priced that way intentionally so you\'re motivated to just host it yourself and save the money.',
  },
  {
    question: 'Do you use AI to build the websites?',
    answer: 'Yes. The page you\'re looking at right now was built with the help of AI — doesn\'t it look good? Here\'s the thing: you or your tech-savvy niece could also build a website with AI tools. But there\'s still a lot that goes on in the background — writing SEO content, setting up hosting, configuring structured data, submitting sitemaps — that AI can\'t quite handle on its own yet. We could teach you all that, but it would cost more than $2,000 and take longer than 7 days. Which is what we\'re offering.',
  },
  {
    question: 'What happens if I stop working with you?',
    answer: 'Nothing changes. That\'s the whole point. Our explicit goal is that you never have to reach back out. No follow-ups, no check-ins, no renewal notices. Your website keeps running on its own. If you ever want to make updates or get interested in more aggressive growth, we\'re here — but it\'s entirely your call.',
  },
  {
    question: 'Will this actually help me get more patients?',
    answer: 'There\'s a saying: "Nice shoes won\'t get you the girl, but bad shoes will lose her." Same thing here. A great website alone won\'t flood your practice with new patients — but a bad one (or no website at all) is actively turning people away. We don\'t promise growth. That\'s a different beast entirely. Our focus is the baseline foundation — the groundwork. You\'ll be set up extremely well for SEO and AI search with authoritative, geographic content. But the basics are really just an optimized Google Business Profile and a professional, accurate website. Real growth requires regular content creation — yes, more articles, yes, even TikToks. Let\'s crawl before we walk.',
  },
  {
    question: 'I already use a service like Tebra for my practice. How is this different?',
    answer: 'Those platforms are full-service practice management systems — patient scheduling, EHR, billing, the works. That\'s a different product solving a different problem. Groundwork isn\'t a practice management tool. It\'s just a website. A really good one that you own outright. Pay once, get your site, done. If you eventually want full-service patient management, you can still use those tools — this complements that journey. But most practices don\'t need all that to start. They just need to look professional online and show up in search results.',
  },
];
---

<BaseLayout
  title="Groundwork Dental — Custom Dental Websites You Actually Own"
  description="Custom SEO-ready dental websites built in days. You own the code, the hosting, and every account. $2,000 flat."
>
  <!-- Hero -->
  <section class="bg-brand-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">For dental practices</p>
        <h1 class="font-serif text-5xl md:text-6xl font-normal leading-tight tracking-tight text-charcoal mb-6">
          The Foundation Your<br />Practice Needs Online.
        </h1>
        <p class="font-serif text-xl text-mid-gray leading-relaxed mb-8 max-w-2xl">
          A modern dental website + optimized Google presence. One flat price.<br class="hidden sm:inline" />
          No&nbsp;monthly&nbsp;fees. No templates. Live in days. You own everything.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/get-started" class="btn-primary px-8 py-3.5">
            Get Started
          </a>
          <a href="/example" class="btn-secondary px-8 py-3.5">
            See an Example
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- The $12/year Number -->
  <section class="py-10 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="eyebrow text-brand-warm mb-4">After the build</p>
      <p class="text-6xl md:text-8xl text-charcoal mb-4 font-mono tracking-tight">~$12<span class="text-mid-gray text-3xl md:text-4xl">/year</span></p>
      <p class="font-serif text-mid-gray text-lg max-w-xl mx-auto leading-relaxed">
        Straight to your domain registrar for renewal — not us. Hosting is free. No monthly agency fees or website builder subscriptions.
      </p>
    </div>
  </section>

  <!-- What You Get -->
  <section class="py-10 bg-surface-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="section-subheading mb-4">What You Get</h2>
        <p class="font-serif text-mid-gray max-w-2xl mx-auto">One price covers every piece of the puzzle. No extras, no upsells.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <FeatureCard
          title="Dedicated Service Pages"
          description="Every service gets its own page with real content — the kind of depth that helps Google understand what you specialize in."
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>'
        />
        <FeatureCard
          title="90+ PageSpeed Score"
          description="Static HTML, zero JavaScript bloat. Your site loads instantly on any device — no plugins slowing things down."
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>'
        />
        <FeatureCard
          title="Google & AI Search Ready"
          description="Structured data on every page so Google, ChatGPT, and Perplexity know exactly what you do and where you are."
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>'
        />
        <FeatureCard
          title="Full SEO Foundation"
          description="Optimized titles, internal linking, sitemap, robots.txt, Open Graph tags. The entire technical baseline, done right."
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>'
        />
        <FeatureCard
          title="Google Business Profile"
          description="Categories, services, photos, and settings configured correctly. The single most important factor for local search."
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>'
        />
        <FeatureCard
          title="You Own Everything"
          description="Code, hosting, domain, analytics — all yours. Walk away tomorrow and your website keeps running. No strings."
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>'
        />
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <ComparisonTable rows={comparisonRows} heading="Traditional Agency vs. Groundwork Dental" />
    </div>
  </section>

  <!-- AI Search -->
  <section class="py-10 bg-surface-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow text-brand-warm mb-4">Beyond Google</p>
        <h2 class="section-subheading mb-4">Show Up When Patients Ask AI</h2>
        <p class="font-serif text-mid-gray leading-relaxed mb-6">
          Patients are asking ChatGPT, Perplexity, and Google AI Overviews for dentist recommendations. These tools pull answers from websites with structured data and authoritative content — exactly what we build into every page. If your website gives AI nothing to work with, you're invisible in the fastest-growing search channel.
        </p>
        <a href="/how-it-works" class="font-sans text-sm text-brand-warm font-medium hover:text-brand-warm-dark transition-colors">
          Learn how it works &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- The Ownership Guarantee -->
  <section class="py-10 bg-charcoal text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <p class="font-sans text-eyebrow uppercase text-neutral-300 mb-4">The guarantee</p>
        <h2 class="font-serif text-3xl md:text-4xl font-normal mb-6">The Ownership Guarantee</h2>
        <p class="font-serif text-lg text-neutral-200 leading-relaxed mb-6">
          After the project's done, you could hand the whole thing off to your tech-savvy niece and let her vibe-code it from there. Seriously. She'll understand what that means, even if you don't. Or open up ChatGPT yourself, tell it what you want changed, and push it live — we'll leave you with everything you need to do that.
        </p>
        <p class="font-serif text-neutral-200 leading-relaxed mb-8">
          The point is: it's yours. Walk away tomorrow, hire someone else, or never talk to us again. Your website keeps working. No strings attached.
        </p>
        <p class="font-sans text-xs text-neutral-300">
          You keep: the domain, the hosting, the website code, the design assets, the SEO content, all Google accounts, all analytics. We walk away clean.
        </p>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-subheading text-center mb-12">How It Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-10 h-10 rounded border border-border-light text-charcoal font-mono text-sm flex items-center justify-center mx-auto mb-4">01</div>
          <h3 class="font-serif text-charcoal mb-2">We Rebuild Your Site</h3>
          <p class="font-serif text-mid-gray text-sm leading-relaxed">Send us your practice info and current website. We'll reach out to walk through what we'd build for you.</p>
        </div>
        <div class="text-center">
          <div class="w-10 h-10 rounded border border-border-light text-charcoal font-mono text-sm flex items-center justify-center mx-auto mb-4">02</div>
          <h3 class="font-serif text-charcoal mb-2">You Review It</h3>
          <p class="font-serif text-mid-gray text-sm leading-relaxed">You get 30 days to review and send feedback. Check your phone, read the content, send feedback as many times as you want until it's right.</p>
        </div>
        <div class="text-center">
          <div class="w-10 h-10 rounded border border-border-light text-charcoal font-mono text-sm flex items-center justify-center mx-auto mb-4">03</div>
          <h3 class="font-serif text-charcoal mb-2">You Own It Forever</h3>
          <p class="font-serif text-mid-gray text-sm leading-relaxed">We transfer everything to your accounts. Your code, your hosting, your domain. Done. ~$12/year to keep it running.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why This Exists -->
  <section class="py-10 bg-surface-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow text-brand-warm mb-4">Why this exists</p>
        <h2 class="section-subheading mb-4">Dentists Deserve Better Websites</h2>
        <p class="font-serif text-mid-gray leading-relaxed mb-6">
          You went to school to fix teeth, not to navigate hosting providers and SEO plugins. But somehow your online presence has become one more thing you're expected to figure out — or overpay someone else to handle. Most dentists don't need anything crazy. Just a professional site that actually shows up when someone searches for a dentist nearby. That shouldn't cost $15,000 or require a monthly subscription.
        </p>
        <a href="/about" class="font-sans text-sm text-brand-warm font-medium hover:text-brand-warm-dark transition-colors">
          Learn more &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock variant="dark" />
    </div>
  </section>
</BaseLayout>
