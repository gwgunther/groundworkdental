---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const allTags = [...new Set(posts.flatMap(post => post.data.tags))].sort();
---

<BaseLayout
  title="Blog — Dental SEO & Website Insights | Groundwork Dental"
  description="Honest insights about dental SEO, website ownership, and what dentists actually need to know about their online presence. No fluff. No upsells."
>
  <!-- Hero -->
  <section class="bg-brand-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-20">
      <div class="max-w-3xl">
        <h1 class="section-heading mb-4">The Blog</h1>
        <p class="font-serif text-xl text-mid-gray leading-relaxed">
          Everything you need to know to get this right — whether you hire us or not.
        </p>
      </div>
    </div>
  </section>

  <!-- Tag Filter -->
  <section class="border-b border-border-light">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex flex-wrap items-center gap-2">
        <button
          class="tag-filter font-sans text-xs px-3 py-1.5 rounded-full border transition-colors duration-200 is-active"
          data-tag="all"
        >
          All
        </button>
        {allTags.map((tag) => (
          <button
            class="tag-filter font-sans text-xs px-3 py-1.5 rounded-full border transition-colors duration-200"
            data-tag={tag}
          >
            {tag}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Posts -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="posts-grid">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="card hover:border-brand-warm transition-colors group"
              data-tags={JSON.stringify(post.data.tags)}
            >
              <div class="flex flex-wrap items-center gap-2 mb-3">
                {post.data.tags.map((tag: string) => (
                  <span class="font-sans text-[10px] uppercase tracking-wider text-brand-warm bg-brand-warm/10 px-2 py-0.5 rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="font-serif text-charcoal mb-2 group-hover:text-brand-warm transition-colors">
                {post.data.title}
              </h2>
              <p class="font-serif text-mid-gray text-sm leading-relaxed mb-3">
                {post.data.description}
              </p>
              <p class="font-sans text-xs text-neutral-400">
                {post.data.publishDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </p>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-8">
          <p class="font-serif text-mid-gray text-lg">Articles coming soon. In the meantime, check out our <a href="/dental-seo-foundation" class="text-brand-warm font-medium hover:text-brand-warm-dark">comprehensive SEO guide</a>.</p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock variant="dark" />
    </div>
  </section>
</BaseLayout>

<style>
  .tag-filter {
    border-color: var(--color-border-light, #e5e5e5);
    color: var(--color-mid-gray, #6b7280);
    background: transparent;
    cursor: pointer;
  }
  .tag-filter:hover,
  .tag-filter.is-active {
    border-color: #C45D3E;
    color: #C45D3E;
    background: rgba(196, 93, 62, 0.08);
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-filter');
  const cards = document.querySelectorAll<HTMLAnchorElement>('#posts-grid > a');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');

      const tag = btn.dataset.tag;

      cards.forEach(card => {
        if (tag === 'all') {
          card.style.display = '';
          return;
        }
        const tags: string[] = JSON.parse(card.dataset.tags || '[]');
        card.style.display = tags.includes(tag!) ? '' : 'none';
      });
    });
  });
</script>
