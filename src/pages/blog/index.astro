---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const categories = ['all', 'dental-seo', 'dental-websites', 'agency-comparison', 'pricing'] as const;
const categoryLabels: Record<string, string> = {
  'all': 'All',
  'dental-seo': 'Dental SEO',
  'dental-websites': 'Websites',
  'agency-comparison': 'Agency Comparison',
  'pricing': 'Pricing',
};
---

<BaseLayout
  title="Blog — Dental SEO & Website Insights | Groundwork Dental"
  description="Honest insights about dental SEO, website design, agency lock-in, and what dentists actually need to know about their online presence. No fluff. No upsells."
>
  <!-- Hero -->
  <section class="bg-brand-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <div class="max-w-3xl">
        <h1 class="section-heading mb-4">The Blog</h1>
        <p class="font-serif text-xl text-mid-gray leading-relaxed">
          Everything we know about dental SEO, websites, and marketing — given away for free. Because dentists will read it, appreciate the honesty, and hire us anyway.
        </p>
      </div>
    </div>
  </section>

  <!-- Posts -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="card hover:border-brand-warm transition-colors group">
              <div class="mb-3">
                <span class="eyebrow text-brand-warm">
                  {categoryLabels[post.data.category] || post.data.category}
                </span>
              </div>
              <h2 class="font-serif text-charcoal mb-2 group-hover:text-brand-warm transition-colors">
                {post.data.title}
              </h2>
              <p class="font-serif text-mid-gray text-sm leading-relaxed mb-3">
                {post.data.description}
              </p>
              <p class="font-sans text-xs text-neutral-400">
                {post.data.publishDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </p>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="font-serif text-mid-gray text-lg">Articles coming soon. In the meantime, check out our <a href="/dental-seo-foundation" class="text-brand-warm font-medium hover:text-brand-warm-dark">comprehensive SEO guide</a>.</p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock variant="dark" />
    </div>
  </section>
</BaseLayout>
