---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQBlock from '../../components/FAQBlock.astro';
import CTABlock from '../../components/CTABlock.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import { getCollection, render } from 'astro:content';
import { site } from '../../config/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  'headline': post.data.title,
  'description': post.data.description,
  'author': {
    '@type': 'Organization',
    'name': site.name,
  },
  'publisher': {
    '@type': 'Organization',
    'name': site.name,
    'url': site.url,
  },
  'datePublished': post.data.publishDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  'mainEntityOfPage': {
    '@type': 'WebPage',
    '@id': `${site.url}/blog/${post.id}`,
  },
};
---

<BaseLayout
  title={`${post.data.title} | Groundwork Dental`}
  description={post.data.description}
  ogType="article"
  articleDate={post.data.publishDate.toISOString()}
  schema={blogPostingSchema}
>
  <article>
    <!-- Header -->
    <section class="bg-brand-cream">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
        <p class="eyebrow text-brand-warm mb-4">
          {post.data.category.replace(/-/g, ' ')}
        </p>
        <h1 class="section-heading mb-6">{post.data.title}</h1>
        <div class="font-sans text-xs text-mid-gray mb-4">
          <time datetime={post.data.publishDate.toISOString()}>
            {post.data.publishDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </time>
        </div>
        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag: string) => (
              <span class="font-sans text-[10px] uppercase tracking-wider text-brand-warm bg-brand-warm/10 px-2 py-0.5 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- Content -->
    <section class="py-10">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="prose-article text-lg">
          <Content />
        </div>
      </div>
    </section>

    <!-- FAQ (if present) -->
    {post.data.faqs && post.data.faqs.length > 0 && (
      <section class="py-16 bg-surface-2">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <FAQBlock faqs={post.data.faqs} />
        </div>
      </section>
    )}
  </article>

  <!-- Related Articles -->
  <RelatedArticles current={post} allPosts={allPosts} />

  <!-- Author Box -->
  <section class="py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="card flex flex-col sm:flex-row items-start gap-4">
        <div>
          <p class="font-serif text-charcoal mb-1">Groundwork</p>
          <p class="font-serif text-sm text-mid-gray leading-relaxed">
            Custom dental websites with full ownership. No lock-in. No retainer. <a href="/about" class="text-brand-warm hover:text-brand-warm-dark">Learn more &rarr;</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock variant="dark" />
    </div>
  </section>
</BaseLayout>
