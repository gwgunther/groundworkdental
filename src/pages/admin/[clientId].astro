---
export const prerender = false;

import IntakeLayout from '../../layouts/IntakeLayout.astro';
import { createAdminClient } from '../../lib/supabase-server';
import { intakeSections } from '../../config/intake-sections';

const { clientId } = Astro.params;
const adminSupabase = createAdminClient();

// Fetch client
const { data: client, error } = await adminSupabase
  .from('clients')
  .select('*')
  .eq('id', clientId)
  .single();

if (error || !client) {
  return Astro.redirect('/admin');
}

// Fetch uploaded files
const { data: files } = await adminSupabase
  .from('client_files')
  .select('*')
  .eq('client_id', clientId)
  .order('uploaded_at', { ascending: false });

// Fetch admin notes
const { data: notes } = await adminSupabase
  .from('admin_notes')
  .select('*')
  .eq('client_id', clientId)
  .order('created_at', { ascending: false });

const sectionsComplete = client.sections_complete || {};
const intakeData = client.intake_data || {};

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
  });
}

function formatFileSize(bytes: number | null) {
  if (!bytes) return '';
  if (bytes < 1024) return `${bytes} B`;
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
}

// Group files by section
const filesBySection: Record<string, typeof files> = {};
files?.forEach((file) => {
  if (!filesBySection[file.section]) filesBySection[file.section] = [];
  filesBySection[file.section]!.push(file);
});
---

<IntakeLayout title={`${client.practice_name || 'Client Detail'} — Admin`}>
  <!-- Header -->
  <div class="mb-8">
    <a href="/admin" class="font-sans text-xs uppercase tracking-widest text-mid-gray hover:text-charcoal transition-colors mb-4 inline-block">
      &larr; All Clients
    </a>
    <h1 class="section-subheading mb-2">{client.practice_name || 'Unnamed Practice'}</h1>
    <div class="flex flex-wrap gap-3 items-center">
      <span class="font-serif text-sm text-mid-gray">{client.contact_email}</span>
      {client.contact_phone && (
        <span class="font-serif text-sm text-mid-gray">{client.contact_phone}</span>
      )}
      {client.intake_status === 'submitted' && <span class="status-badge-complete">Submitted</span>}
      {client.intake_status === 'reviewed' && <span class="status-badge-complete">Reviewed</span>}
      {client.intake_status === 'in_progress' && <span class="status-badge-progress">In Progress</span>}
      {client.intake_status === 'not_started' && <span class="status-badge-pending">Not Started</span>}
      {client.payment_status === 'paid' && <span class="status-badge-complete">Paid</span>}
      {client.payment_status === 'unpaid' && <span class="status-badge-pending">Unpaid</span>}
    </div>
    <p class="font-serif text-xs text-mid-gray mt-2">
      Created {formatDate(client.created_at)} · Last updated {formatDate(client.updated_at)}
    </p>
  </div>

  <!-- Intake Sections -->
  <div class="space-y-6 mb-10">
    {intakeSections.map((section) => {
      const isComplete = sectionsComplete[section.id] === true;
      const sectionData = intakeData[section.id];
      const sectionFiles = filesBySection[section.id];
      const hasData = sectionData && Object.keys(sectionData).length > 0;

      return (
        <div class="card bg-white">
          <div class="flex items-center justify-between mb-4">
            <h2 class="font-serif text-charcoal">{section.title}</h2>
            {isComplete && <span class="status-badge-complete">Complete</span>}
            {!isComplete && hasData && <span class="status-badge-progress">In Progress</span>}
            {!isComplete && !hasData && <span class="status-badge-pending">Empty</span>}
          </div>

          {hasData ? (
            <div class="space-y-3">
              {Object.entries(sectionData).map(([key, value]) => {
                const label = key.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());

                // Handle arrays (like service checklists)
                if (Array.isArray(value)) {
                  return (
                    <div>
                      <dt class="font-sans text-xs uppercase tracking-widest text-mid-gray mb-1">{label}</dt>
                      <dd class="font-serif text-sm text-charcoal">
                        {value.length > 0 ? (
                          <ul class="list-disc list-inside space-y-0.5">
                            {value.map((item: any) => (
                              <li>{typeof item === 'object' ? JSON.stringify(item) : String(item)}</li>
                            ))}
                          </ul>
                        ) : (
                          <span class="text-mid-gray italic">None</span>
                        )}
                      </dd>
                    </div>
                  );
                }

                // Handle objects
                if (typeof value === 'object' && value !== null) {
                  return (
                    <div>
                      <dt class="font-sans text-xs uppercase tracking-widest text-mid-gray mb-1">{label}</dt>
                      <dd class="font-serif text-sm text-charcoal">
                        <pre class="bg-surface-2 rounded p-3 text-xs font-mono overflow-x-auto">{JSON.stringify(value, null, 2)}</pre>
                      </dd>
                    </div>
                  );
                }

                // Handle booleans
                if (typeof value === 'boolean') {
                  return (
                    <div>
                      <dt class="font-sans text-xs uppercase tracking-widest text-mid-gray mb-1">{label}</dt>
                      <dd class="font-serif text-sm text-charcoal">{value ? 'Yes' : 'No'}</dd>
                    </div>
                  );
                }

                // Strings / numbers
                return (
                  <div>
                    <dt class="font-sans text-xs uppercase tracking-widest text-mid-gray mb-1">{label}</dt>
                    <dd class="font-serif text-sm text-charcoal whitespace-pre-wrap">{String(value) || <span class="text-mid-gray italic">—</span>}</dd>
                  </div>
                );
              })}
            </div>
          ) : (
            <p class="font-serif text-sm text-mid-gray italic">No data submitted for this section.</p>
          )}

          {/* Files for this section */}
          {sectionFiles && sectionFiles.length > 0 && (
            <div class="mt-4 pt-4 border-t border-border-light">
              <h3 class="font-sans text-xs uppercase tracking-widest text-mid-gray mb-3">Uploaded Files</h3>
              <div class="space-y-2">
                {sectionFiles.map((file: any) => (
                  <div class="flex items-center justify-between bg-surface-2 rounded px-3 py-2">
                    <div>
                      <p class="font-serif text-sm text-charcoal">{file.file_name}</p>
                      <p class="font-sans text-xs text-mid-gray">
                        {file.label && `${file.label} · `}{formatFileSize(file.file_size)} · {formatDate(file.uploaded_at)}
                      </p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      );
    })}
  </div>

  <!-- Admin Notes -->
  <div class="mb-8">
    <h2 class="section-subheading mb-4">Notes</h2>

    {notes && notes.length > 0 && (
      <div class="space-y-3 mb-6">
        {notes.map((note: any) => (
          <div class="card bg-white">
            <p class="font-serif text-sm text-charcoal whitespace-pre-wrap">{note.note}</p>
            <p class="font-sans text-xs text-mid-gray mt-2">{formatDate(note.created_at)}</p>
          </div>
        ))}
      </div>
    )}

    <div class="card bg-white">
      <textarea
        id="new-note"
        class="form-input w-full min-h-[80px] resize-y mb-3"
        placeholder="Add a note..."
      ></textarea>
      <button
        id="save-note-btn"
        class="btn-primary text-sm px-4 py-2"
        data-client-id={client.id}
      >
        Save Note
      </button>
    </div>
  </div>

  <!-- Status overrides -->
  <div class="mb-8">
    <h2 class="section-subheading mb-4">Actions</h2>
    <div class="card bg-white flex flex-wrap gap-3">
      <button class="btn-secondary text-sm px-4 py-2 admin-status-btn" data-status="reviewed">Mark as Reviewed</button>
      <button class="btn-secondary text-sm px-4 py-2 admin-status-btn" data-status="in_progress">Reopen Intake</button>
      <button class="btn-secondary text-sm px-4 py-2 admin-payment-btn" data-payment="paid">Mark as Paid</button>
      <button class="btn-secondary text-sm px-4 py-2 admin-payment-btn" data-payment="refunded">Mark as Refunded</button>
    </div>
  </div>

  <script define:vars={{ clientId: client.id }}>
    const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
    const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    async function getSupabase() {
      const { createClient } = await import('https://esm.sh/@supabase/supabase-js@2');
      return createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
    }

    // Save note
    document.getElementById('save-note-btn')?.addEventListener('click', async () => {
      const textarea = document.getElementById('new-note');
      const note = textarea?.value?.trim();
      if (!note) return;

      const supabase = await getSupabase();
      const { error } = await supabase.from('admin_notes').insert({
        client_id: clientId,
        note,
      });

      if (!error) window.location.reload();
    });

    // Status buttons
    document.querySelectorAll('.admin-status-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const status = btn.dataset.status;
        const supabase = await getSupabase();
        await supabase.from('clients').update({ intake_status: status }).eq('id', clientId);
        window.location.reload();
      });
    });

    // Payment buttons
    document.querySelectorAll('.admin-payment-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const payment = btn.dataset.payment;
        const updates = { payment_status: payment };
        if (payment === 'paid') updates.paid_at = new Date().toISOString();
        const supabase = await getSupabase();
        await supabase.from('clients').update(updates).eq('id', clientId);
        window.location.reload();
      });
    });
  </script>
</IntakeLayout>
