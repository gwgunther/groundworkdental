---
export const prerender = false;

import IntakeLayout from '../../layouts/IntakeLayout.astro';
import { createAdminClient } from '../../lib/supabase-server';
import { intakeSections } from '../../config/intake-sections';

const adminSupabase = createAdminClient();

// Fetch all clients
const { data: clients, error } = await adminSupabase
  .from('clients')
  .select('id, practice_name, contact_email, intake_status, sections_complete, payment_status, created_at, updated_at')
  .order('updated_at', { ascending: false });

const totalSections = intakeSections.length;

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

function completedCount(sectionsComplete: Record<string, boolean> | null) {
  if (!sectionsComplete) return 0;
  return Object.values(sectionsComplete).filter(Boolean).length;
}
---

<IntakeLayout title="Admin Dashboard">
  <div class="mb-8">
    <h1 class="section-subheading mb-2">Clients</h1>
    <p class="font-serif text-mid-gray">
      {clients?.length || 0} total clients
    </p>
  </div>

  {error && (
    <div class="card bg-red-50 border-red-200 mb-6">
      <p class="font-serif text-red-700 text-sm">Error loading clients: {error.message}</p>
    </div>
  )}

  {(!clients || clients.length === 0) && !error && (
    <div class="card bg-white text-center py-12">
      <p class="font-serif text-mid-gray">No clients yet. They'll appear here once they sign into their intake form.</p>
    </div>
  )}

  {clients && clients.length > 0 && (
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-border-light">
            <th class="font-sans text-xs uppercase tracking-widest text-mid-gray text-left py-3 pr-4">Practice</th>
            <th class="font-sans text-xs uppercase tracking-widest text-mid-gray text-left py-3 pr-4">Email</th>
            <th class="font-sans text-xs uppercase tracking-widest text-mid-gray text-left py-3 pr-4">Intake</th>
            <th class="font-sans text-xs uppercase tracking-widest text-mid-gray text-left py-3 pr-4">Sections</th>
            <th class="font-sans text-xs uppercase tracking-widest text-mid-gray text-left py-3 pr-4">Payment</th>
            <th class="font-sans text-xs uppercase tracking-widest text-mid-gray text-left py-3">Updated</th>
          </tr>
        </thead>
        <tbody>
          {clients.map((client) => {
            const completed = completedCount(client.sections_complete);
            return (
              <tr class="border-b border-border-light hover:bg-surface-2 transition-colors">
                <td class="py-3 pr-4">
                  <a
                    href={`/admin/${client.id}`}
                    class="font-serif text-charcoal hover:text-brand-warm transition-colors"
                  >
                    {client.practice_name || 'Unnamed Practice'}
                  </a>
                </td>
                <td class="py-3 pr-4">
                  <span class="font-serif text-sm text-mid-gray">{client.contact_email}</span>
                </td>
                <td class="py-3 pr-4">
                  {client.intake_status === 'submitted' && (
                    <span class="status-badge-complete">Submitted</span>
                  )}
                  {client.intake_status === 'reviewed' && (
                    <span class="status-badge-complete">Reviewed</span>
                  )}
                  {client.intake_status === 'in_progress' && (
                    <span class="status-badge-progress">In Progress</span>
                  )}
                  {client.intake_status === 'not_started' && (
                    <span class="status-badge-pending">Not Started</span>
                  )}
                </td>
                <td class="py-3 pr-4">
                  <span class="font-mono text-sm text-charcoal">{completed}/{totalSections}</span>
                </td>
                <td class="py-3 pr-4">
                  {client.payment_status === 'paid' && (
                    <span class="status-badge-complete">Paid</span>
                  )}
                  {client.payment_status === 'unpaid' && (
                    <span class="status-badge-pending">Unpaid</span>
                  )}
                  {client.payment_status === 'refunded' && (
                    <span class="status-badge-progress">Refunded</span>
                  )}
                </td>
                <td class="py-3">
                  <span class="font-serif text-sm text-mid-gray">{formatDate(client.updated_at)}</span>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}
</IntakeLayout>
