---
export const prerender = false;

import { site } from '../../config/site';
import { createAdminClient } from '../../lib/supabase-server';
import '../../styles/global.css';

const { token } = Astro.params;
const supabase = createAdminClient();

// Look up handoff by token
const { data: handoff, error } = await supabase
  .from('handoffs')
  .select('*')
  .eq('token', token)
  .single();

if (error || !handoff) {
  return new Response('Not found', { status: 404 });
}

// Password gate — check cookie or query param
const cookieKey = `handoff-${token}`;
const hasAccess = Astro.cookies.get(cookieKey)?.value === 'granted';

if (!hasAccess) {
  const formData = Astro.request.method === 'POST'
    ? await Astro.request.formData()
    : null;
  const submitted = formData?.get('password')?.toString();

  if (submitted && submitted === handoff.password) {
    Astro.cookies.set(cookieKey, 'granted', {
      path: `/handoff/${token}`,
      maxAge: 60 * 60 * 24 * 365,
      httpOnly: true,
      sameSite: 'lax',
    });
  } else {
    const showError = submitted !== undefined && submitted !== null;
    // Render password gate
    return new Response(
      `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Client Portal — ${site.name}</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/styles/global.css" />
  <style>
    body { font-family: 'DM Sans', sans-serif; background: #FAF8F5; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .gate { max-width: 400px; width: 100%; padding: 2rem; text-align: center; }
    .gate h1 { font-family: 'DM Serif Display', serif; font-size: 1.5rem; color: #1A1A1A; margin-bottom: 0.5rem; }
    .gate p { color: #6b7280; font-size: 0.875rem; margin-bottom: 1.5rem; }
    .gate input { display: block; width: 100%; padding: 0.75rem 1rem; border: 1px solid #e5e5e5; border-radius: 0.375rem; font-size: 0.875rem; margin-bottom: 1rem; background: white; }
    .gate button { background: #C45D3E; color: white; padding: 0.75rem 2rem; border: none; border-radius: 0.375rem; font-size: 0.875rem; font-weight: 500; cursor: pointer; width: 100%; }
    .gate button:hover { background: #a84d33; }
    .error { color: #C45D3E; font-size: 0.75rem; margin-bottom: 1rem; }
  </style>
</head>
<body>
  <div class="gate">
    <h1>Client Portal</h1>
    <p>Enter your access code to view your handoff documentation.</p>
    ${showError ? '<p class="error">Incorrect access code. Please try again.</p>' : ''}
    <form method="POST">
      <input type="password" name="password" placeholder="Access code" autofocus required />
      <button type="submit">View Documentation</button>
    </form>
  </div>
</body>
</html>`,
      { status: 200, headers: { 'Content-Type': 'text/html' } }
    );
  }
}

const accounts = handoff.accounts || [];
const practiceName = handoff.practice_name || 'Your Practice';
const completedDate = handoff.completed_at
  ? new Date(handoff.completed_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{practiceName} — Handoff Documentation</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=DM+Serif+Display&display=swap" rel="stylesheet" />
</head>
<body class="bg-brand-cream min-h-screen">
  <!-- Header -->
  <header class="bg-white border-b border-border-light">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between">
      <span class="font-serif text-lg text-charcoal">
        Groundwork <span class="text-brand-warm">Dental</span>
      </span>
      <span class="font-sans text-xs text-mid-gray">Client Portal</span>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    <!-- Title -->
    <div class="mb-10">
      <h1 class="font-serif text-3xl text-charcoal mb-2">{practiceName}</h1>
      <p class="font-serif text-mid-gray">
        Handoff documentation{completedDate && <span> — completed {completedDate}</span>}
      </p>
    </div>

    <!-- Quick Reference -->
    <div class="card bg-white mb-8">
      <h2 class="font-serif text-charcoal text-lg mb-4">What You Own</h2>
      <p class="font-serif text-mid-gray text-sm leading-relaxed mb-4">
        Everything listed below is in your name. We have collaborator/editor access so we can help if needed — but you're the owner. Revoke our access anytime and nothing changes.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-sage flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          <span class="font-sans text-xs text-charcoal">Domain registration</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-sage flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          <span class="font-sans text-xs text-charcoal">Website code & hosting</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-sage flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          <span class="font-sans text-xs text-charcoal">Google Analytics & Search Console</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-sage flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          <span class="font-sans text-xs text-charcoal">Google Business Profile</span>
        </div>
      </div>
    </div>

    <!-- Accounts -->
    <div class="space-y-6 mb-10">
      <h2 class="font-serif text-charcoal text-lg">Your Accounts</h2>

      {accounts.map((account: any) => (
        <div class="card bg-white">
          <div class="flex items-start justify-between mb-3">
            <h3 class="font-serif text-charcoal">{account.name}</h3>
            {account.url && (
              <a href={account.url} target="_blank" rel="noopener" class="font-sans text-xs text-brand-warm hover:text-brand-warm-dark">
                Open &rarr;
              </a>
            )}
          </div>
          {account.description && (
            <p class="font-serif text-mid-gray text-sm leading-relaxed mb-3">{account.description}</p>
          )}
          <dl class="space-y-2">
            {account.username && (
              <div class="flex items-baseline gap-2">
                <dt class="font-sans text-xs uppercase tracking-widest text-mid-gray w-24 flex-shrink-0">Account</dt>
                <dd class="font-mono text-sm text-charcoal">{account.username}</dd>
              </div>
            )}
            {account.details && Object.entries(account.details).map(([key, value]: [string, any]) => (
              <div class="flex items-baseline gap-2">
                <dt class="font-sans text-xs uppercase tracking-widest text-mid-gray w-24 flex-shrink-0">{key}</dt>
                <dd class="font-mono text-sm text-charcoal">{value}</dd>
              </div>
            ))}
          </dl>
          {account.instructions && (
            <div class="mt-4 pt-3 border-t border-border-light">
              <p class="font-sans text-xs uppercase tracking-widest text-mid-gray mb-2">How to access</p>
              <p class="font-serif text-sm text-charcoal leading-relaxed">{account.instructions}</p>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Common Tasks -->
    <div class="card bg-white mb-8">
      <h2 class="font-serif text-charcoal text-lg mb-4">Common Tasks</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-sans text-xs uppercase tracking-widest text-mid-gray mb-1">Renew your domain</h3>
          <p class="font-serif text-sm text-charcoal leading-relaxed">Log in to your domain registrar once a year and renew. Cost is ~$12/year. You'll get email reminders before it expires.</p>
        </div>
        <div>
          <h3 class="font-sans text-xs uppercase tracking-widest text-mid-gray mb-1">Update website content</h3>
          <p class="font-serif text-sm text-charcoal leading-relaxed">Your site code lives in your GitHub repository. Edit the files directly on GitHub, or hand the repo URL to any developer. Changes deploy automatically via Cloudflare Pages.</p>
        </div>
        <div>
          <h3 class="font-sans text-xs uppercase tracking-widest text-mid-gray mb-1">Check your analytics</h3>
          <p class="font-serif text-sm text-charcoal leading-relaxed">Visit analytics.google.com and sign in with your Google account. Your property is already set up and tracking.</p>
        </div>
        <div>
          <h3 class="font-sans text-xs uppercase tracking-widest text-mid-gray mb-1">Update your Google Business Profile</h3>
          <p class="font-serif text-sm text-charcoal leading-relaxed">Search your practice name on Google while signed in, or go to business.google.com. You can update hours, photos, services, and respond to reviews directly.</p>
        </div>
      </div>
    </div>

    <!-- Credentials note -->
    <div class="card bg-surface-2 border-brand-warm/20 mb-8">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-brand-warm flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div>
          <h3 class="font-serif text-charcoal text-sm mb-1">About passwords</h3>
          <p class="font-serif text-mid-gray text-sm leading-relaxed">
            For security, passwords are not stored on this page. Your login credentials were shared separately via a secure, encrypted link. If you need them again, email <a href={`mailto:${site.email}`} class="text-brand-warm hover:text-brand-warm-dark">{site.email}</a> and we'll send a new secure link.
          </p>
        </div>
      </div>
    </div>

    <!-- Support -->
    <div class="text-center py-6">
      <p class="font-serif text-mid-gray text-sm mb-2">Need help with anything?</p>
      <a href={`mailto:${site.email}`} class="font-sans text-sm text-brand-warm font-medium hover:text-brand-warm-dark">
        {site.email}
      </a>
    </div>
  </main>
</body>
</html>
