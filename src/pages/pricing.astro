---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingTable from '../components/PricingTable.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import FAQBlock from '../components/FAQBlock.astro';
import CTABlock from '../components/CTABlock.astro';
import { site } from '../config/site';

const buildHref = site.stripe.websiteBuild || `mailto:${site.email}?subject=Website%20Build&body=I'm%20interested%20in%20getting%20a%20custom%20dental%20website.%20Here's%20my%20current%20site%3A%20`;
const hostingHref = site.stripe.managedHosting || `mailto:${site.email}?subject=Managed%20Hosting&body=I'm%20interested%20in%20managed%20hosting%20for%20my%20dental%20website.`;

const tiers = [
  {
    name: 'Website Build',
    price: '$2,000',
    period: 'one-time',
    description: 'Everything you need. Custom website, SEO foundation, all accounts set up and transferred to you.',
    highlighted: true,
    cta: 'Get Started',
    href: buildHref,
    features: [
      { text: 'Dedicated page per service category', included: true },
      { text: '100% unique design (no templates)', included: true },
      { text: 'Built to show up in Google search results', included: true },
      { text: 'Structured data so Google understands your site', included: true },
      { text: 'Google Business Profile optimization', included: true },
      { text: 'Google Analytics + Search Console setup', included: true },
      { text: 'Blog ready to publish articles', included: true },
      { text: 'Links to your existing booking/patient management system', included: true },
      { text: 'Before/after photo gallery', included: true },
      { text: 'Looks great on every device', included: true },
      { text: 'Loads fast (90+ speed score)', included: true },
      { text: 'You own everything — code, hosting, accounts', included: true },
    ],
  },
  {
    name: 'Managed Hosting',
    price: '$100',
    period: '/month',
    description: "I do not recommend this. Seriously — it's a little extra work to own your accounts, but you're capable of it. Your hosting is free after the build and the only recurring cost is ~$12/year for your domain. I intentionally priced this high to discourage you. Only if you truly want a completely hands-off experience should you consider it. This option exists for practices that would rather not touch any of the technical accounts — hosting, domain, analytics — and want someone else holding the keys. But save your money. If something comes up down the road — a one-off update, a new page, a quick fix — you can always reach out and pay for it as needed. No retainer required.",
    highlighted: false,
    cta: 'Add After Build',
    href: hostingHref,
    features: [
      { text: 'Everything in Website Build', included: true },
      { text: 'We keep your site running and up to date', included: true },
      { text: 'Content changes whenever you need them', included: true },
      { text: 'Security patches and software updates', included: true },
      { text: 'Monthly report on how your site is doing', included: true },
      { text: 'Priority email support', included: true },
      { text: 'One bill, one point of contact — no juggling accounts', included: true },
    ],
  },
];

const fullComparison = [
  { feature: 'Setup cost',        wix: 'Free',              squarespace: 'Free',          traditional: '$2,000+',        groundwork: '$2,000 flat' },
  { feature: 'Monthly fee',       wix: '$0 (Wix ads shown)', squarespace: '$16+/mo',      traditional: '$200+/mo',       groundwork: '$0 (hosting is free)' },
  { feature: 'Year 1 cost',       wix: '$0',                squarespace: '$192+',         traditional: '$4,400+',        groundwork: '$2,000' },
  { feature: 'Year 2 cost',       wix: '$0',                squarespace: '$192+',         traditional: '$2,400+',        groundwork: '~$12' },
  { feature: 'Year 3 cost',       wix: '$0',                squarespace: '$192+',         traditional: '$2,400+',        groundwork: '~$12' },
  { feature: '3-year total',      wix: '$0 (your time)',    squarespace: '$576+',         traditional: '$9,200+',        groundwork: '$2,024' },
  { feature: 'Pages',             wix: '5–10 (you build)', squarespace: '5–10 (you build)', traditional: '10–20',       groundwork: '10+ (service category pages)' },
  { feature: 'Design',            wix: 'Wix templates',    squarespace: 'SS templates',  traditional: 'Shared across clients', groundwork: '100% custom' },
  { feature: 'Speed',             wix: 'Slow',             squarespace: 'Moderate',      traditional: 'Slow–moderate',  groundwork: '90+ PageSpeed' },
  { feature: 'Google Business Profile', wix: 'Not included', squarespace: 'Not included', traditional: 'Sometimes, extra cost', groundwork: 'Included' },
  { feature: 'Ownership',         wix: 'Wix controls hosting', squarespace: 'SS controls hosting', traditional: 'Agency controls everything', groundwork: 'You own code, hosting, domain' },
  { feature: 'If you leave',      wix: 'Limited export',   squarespace: 'Limited export',  traditional: 'Varies by provider', groundwork: 'Nothing changes' },
];

const faqs = [
  {
    question: 'Why is it only $2,000 when other agencies charge $5,000–$15,000?',
    answer: 'Modern development tools — including AI-assisted workflows — have made it possible for a skilled engineer to build high-quality, unique websites dramatically faster than a traditional agency team. The $15k firm is using the same tools. They just have more people, more overhead, and more reasons to keep you paying. $2,000 is the minimum cost to have a properly built website. The difference is we pass the efficiency gains to you instead of pocketing them.',
  },
  {
    question: "What's the ~$12/year cost after the build?",
    answer: "That's your domain renewal (like yourpractice.com), and it goes directly to your domain registrar — not to us. We don't touch that money. Your website hosting is free through Cloudflare Pages — a service built by one of the largest internet infrastructure companies in the world. They offer free hosting for static websites because it costs them almost nothing to serve fast, lightweight pages from their global network. Your code lives in your own account. We walk away clean.",
  },
  {
    question: 'Do I really not need managed hosting?',
    answer: "I don't recommend it — and I intentionally priced it high to discourage you. Your hosting is free after the build. The only recurring cost is ~$12/year for your domain, paid directly to your registrar. There are no plugins to update, no security holes to patch, no database to manage. You're capable of owning your own accounts. If you need a change down the road, reach out and pay for it as needed. No retainer required.",
  },
  {
    question: 'Can I self-host and pay $0/month?',
    answer: 'Yes. After the build, your only cost is ~$12/year for the domain renewal (paid to your registrar). The site runs on Cloudflare Pages (free), the code lives on GitHub (free), and you own everything.',
  },
  {
    question: 'What if I want changes after the build?',
    answer: "If you're on managed hosting, content updates are included. If you're self-hosting, you can hire any developer to make changes — the site is built with standard, well-documented technology. No proprietary systems, no lock-in.",
  },
  {
    question: 'Is there a contract or commitment?',
    answer: "The website build is a one-time payment. Managed hosting is month-to-month — cancel anytime. No contracts. No cancellation fees. No \"90-day notice period.\" If you want to stop, just stop.",
  },
  {
    question: 'Do you offer refunds?',
    answer: "We build a preview before you commit. You see the finished work, click around, check it on your phone. If you like it, you pay. If you don't, you owe nothing. That's the deal.",
  },
  {
    question: "What's NOT included?",
    answer: "Paid advertising, complex software integrations, patient portal development, and ongoing marketing strategy. We build the website and Google Business Profile foundation — but not a full marketing department. No ongoing content creation unless you ask for it separately.",
  },
];
---

<BaseLayout
  title="Pricing — Groundwork Dental | $2,000 Custom Dental Website"
  description="Straightforward pricing. $2,000 for a custom dental website. $100/month optional managed hosting. No hidden fees. No 'contact us for a quote.' The actual price."
>
  <!-- Hero -->
  <section class="bg-surface-warm">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="section-heading mb-6">The Price Is Right Here.</h1>
        <p class="font-serif text-xl text-mid-gray leading-relaxed">
          No "contact us for a quote." No "starting at." No asterisks. Just the actual number, right here on the page — because that's how it should work.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing Table -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <PricingTable tiers={tiers} />
    </div>
  </section>

  <!-- Full Comparison -->
  <section class="py-10 bg-surface-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 class="section-subheading mb-4">How the Options Compare</h2>
        <p class="font-serif text-mid-gray max-w-2xl mx-auto">Wix is free but shows their ads on your site. Squarespace charges monthly. Traditional agencies charge monthly forever. Here's what that actually costs over time.</p>
      </div>
      <ComparisonTable rows={fullComparison} heading="" />
      <div class="text-center mt-6">
        <p class="font-serif text-sm text-mid-gray italic">Traditional agency assumes $200/mo ongoing after setup. Groundwork assumes $2,000 build + self-hosted. The ~$12/year domain renewal goes directly to your registrar — not to us.</p>
      </div>
    </div>
  </section>

  <!-- What's Included Detail -->
  <section class="py-10" id="get-started">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <h2 class="section-subheading text-center mb-8">What's Included in the $2,000 Build</h2>
        <div class="font-serif space-y-4 text-mid-gray leading-relaxed">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="card">
              <h3 class="font-serif text-charcoal mb-2">Your Website</h3>
              <ul class="font-serif text-sm space-y-1.5">
                <li>Dedicated page per service category</li>
                <li>Homepage, about, FAQ, gallery, and more</li>
                <li>Blog ready to publish articles</li>
                <li>Before/after photo gallery</li>
                <li>Links to your booking system</li>
                <li>FAQ pages with expandable answers</li>
                <li>Insurance and financing info</li>
                <li>Pages for nearby cities you serve</li>
              </ul>
            </div>
            <div class="card">
              <h3 class="font-serif text-charcoal mb-2">Design & Speed</h3>
              <ul class="font-serif text-sm space-y-1.5">
                <li>100% custom — no template reused</li>
                <li>Unique colors and fonts for your practice</li>
                <li>Looks great on phones, tablets, desktops</li>
                <li>Loads fast (90+ Google speed score)</li>
                <li>Clean, modern code — no bloat</li>
                <li>Optimized images throughout</li>
              </ul>
            </div>
            <div class="card">
              <h3 class="font-serif text-charcoal mb-2">Search Visibility</h3>
              <ul class="font-serif text-sm space-y-1.5">
                <li>Every page written to rank in Google</li>
                <li>Structured data so Google understands your services, location, and credentials</li>
                <li>Sitemap submitted to search engines</li>
                <li>Pages linked together for better ranking</li>
                <li>Social media preview cards</li>
                <li>Optimized for AI search (ChatGPT, Perplexity, Google AI Overviews)</li>
              </ul>
            </div>
            <div class="card">
              <h3 class="font-serif text-charcoal mb-2">Accounts & Handoff</h3>
              <ul class="font-serif text-sm space-y-1.5">
                <li>Google Analytics set up and tracking</li>
                <li>Google Search Console verified</li>
                <li>Google Business Profile optimized</li>
                <li>Directory listings checked for accuracy</li>
                <li>All code in your own account</li>
                <li>Free hosting set up in your name</li>
                <li>Complete handoff documentation</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-10 bg-surface-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock
        heading="Ready to Get Started?"
        subheading="Send us your practice info and current website. We'll reach out to walk through what we'd build for you. No commitment, no pressure."
        variant="warm"
        primaryCTA="Get in Touch"
        primaryHref="/get-started"
        secondaryCTA="See an example first"
        secondaryHref="/example"
      />
    </div>
  </section>
</BaseLayout>
