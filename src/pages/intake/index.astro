---
export const prerender = false;

import IntakeLayout from '../../layouts/IntakeLayout.astro';
import { createServerClient } from '../../lib/supabase-server';
import { intakeSections } from '../../config/intake-sections';

const user = Astro.locals.user;
const supabase = createServerClient(Astro.cookies);

// Fetch client record
const { data: client } = await supabase
  .from('clients')
  .select('id, practice_name, intake_data, sections_complete, intake_status')
  .eq('auth_user_id', user.id)
  .single();

const sectionsComplete = client?.sections_complete || {};
const completedCount = Object.values(sectionsComplete).filter(Boolean).length;
const totalSections = intakeSections.length;
const progressPercent = Math.round((completedCount / totalSections) * 100);
---

<IntakeLayout title="Client Workspace">
  <div class="mb-8">
    <h1 class="section-subheading mb-2">
      {client?.practice_name ? `Welcome, ${client.practice_name}` : 'Welcome'}
    </h1>
    <p class="font-serif text-mid-gray">
      Fill out the sections below to help us build your website. Take your time — everything saves automatically.
    </p>
  </div>

  <!-- Progress bar -->
  <div class="mb-8">
    <div class="flex items-center justify-between mb-2">
      <span class="font-sans text-xs text-mid-gray uppercase tracking-widest">{completedCount} of {totalSections} sections</span>
      <span class="font-sans text-xs text-mid-gray">{progressPercent}%</span>
    </div>
    <div class="w-full bg-border-light rounded-full h-1.5">
      <div
        class="bg-brand-warm h-1.5 rounded-full transition-all duration-500"
        style={`width: ${progressPercent}%`}
      ></div>
    </div>
  </div>

  <!-- Section cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {intakeSections.map((section) => {
      const isComplete = sectionsComplete[section.id] === true;
      const hasData = client?.intake_data?.[section.id] && Object.keys(client.intake_data[section.id]).length > 0;
      const status = isComplete ? 'complete' : hasData ? 'progress' : 'pending';

      return (
        <a
          href={`/intake/${section.slug}`}
          class="card bg-white hover:border-brand-warm/40 transition-all group"
        >
          <div class="flex items-start justify-between mb-2">
            <h2 class="font-serif text-charcoal group-hover:text-brand-warm transition-colors">
              {section.title}
            </h2>
            {status === 'complete' && (
              <span class="status-badge-complete">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                Done
              </span>
            )}
            {status === 'progress' && (
              <span class="status-badge-progress">In Progress</span>
            )}
            {status === 'pending' && (
              <span class="status-badge-pending">Not Started</span>
            )}
          </div>
          <p class="font-serif text-sm text-mid-gray">{section.description}</p>
          {section.required && (
            <p class="font-sans text-xs text-brand-warm mt-2">Required</p>
          )}
        </a>
      );
    })}
  </div>

  {client?.intake_status !== 'submitted' && completedCount === totalSections && (
    <div class="mt-8 text-center">
      <p class="font-serif text-mid-gray mb-4">All sections complete. Ready to submit?</p>
      <button
        id="submit-intake"
        class="btn-primary"
        data-client-id={client?.id}
      >
        Submit for Review
      </button>
    </div>
  )}

  {client?.intake_status === 'submitted' && (
    <div class="mt-8 text-center card bg-white">
      <p class="font-serif text-charcoal">Your intake has been submitted. We'll be in touch soon.</p>
    </div>
  )}

  <script>
    document.getElementById('submit-intake')?.addEventListener('click', async (e) => {
      const btn = e.target as HTMLButtonElement;
      const clientId = btn.dataset.clientId;
      btn.textContent = 'Submitting...';
      btn.disabled = true;

      try {
        const { createClient } = await import('https://esm.sh/@supabase/supabase-js@2');
        const supabase = createClient(
          import.meta.env.PUBLIC_SUPABASE_URL,
          import.meta.env.PUBLIC_SUPABASE_ANON_KEY
        );
        await supabase
          .from('clients')
          .update({ intake_status: 'submitted' })
          .eq('id', clientId);
        window.location.reload();
      } catch {
        btn.textContent = 'Submit for Review';
        btn.disabled = false;
      }
    });
  </script>
</IntakeLayout>
