---
export const prerender = false;

import IntakeLayout from '../../layouts/IntakeLayout.astro';
import { createServerClient } from '../../lib/supabase-server';
import { intakeSections, getSectionBySlug } from '../../config/intake-sections';

// React form components
import PracticeInfoForm from '../../components/intake/PracticeInfoForm';
import DoctorTeamForm from '../../components/intake/DoctorTeamForm';
import ServicesForm from '../../components/intake/ServicesForm';
import InsuranceFinancingForm from '../../components/intake/InsuranceFinancingForm';
import BrandingForm from '../../components/intake/BrandingForm';
import ExistingAccountsForm from '../../components/intake/ExistingAccountsForm';
import PhotosForm from '../../components/intake/PhotosForm';
import ContentForm from '../../components/intake/ContentForm';

const { section: sectionSlug } = Astro.params;
const section = getSectionBySlug(sectionSlug || '');

if (!section) {
  return Astro.redirect('/intake');
}

const user = Astro.locals.user;
const supabase = createServerClient(Astro.cookies);

const { data: client } = await supabase
  .from('clients')
  .select('id, intake_data, sections_complete')
  .eq('auth_user_id', user.id)
  .single();

const sectionData = client?.intake_data?.[section.id] || {};
const isComplete = client?.sections_complete?.[section.id] === true;

// Find prev/next sections for navigation
const currentIndex = intakeSections.findIndex(s => s.id === section.id);
const prevSection = currentIndex > 0 ? intakeSections[currentIndex - 1] : null;
const nextSection = currentIndex < intakeSections.length - 1 ? intakeSections[currentIndex + 1] : null;

const formComponents: Record<string, any> = {
  'practice_info': PracticeInfoForm,
  'doctor_team': DoctorTeamForm,
  'services': ServicesForm,
  'insurance_financing': InsuranceFinancingForm,
  'branding': BrandingForm,
  'existing_accounts': ExistingAccountsForm,
  'photos': PhotosForm,
  'content': ContentForm,
};

const FormComponent = formComponents[section.id];

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<IntakeLayout title={section.title}>
  <!-- Back to dashboard -->
  <a href="/intake" class="inline-flex items-center gap-1 font-sans text-xs text-mid-gray hover:text-charcoal transition-colors mb-6 uppercase tracking-widest">
    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
    All Sections
  </a>

  <div class="max-w-2xl">
    <div class="flex items-start justify-between mb-6">
      <div>
        <h1 class="section-subheading mb-1">{section.title}</h1>
        <p class="font-serif text-mid-gray text-sm">{section.description}</p>
      </div>
    </div>

    {FormComponent && (
      <FormComponent
        client:load
        clientId={client?.id}
        sectionId={section.id}
        initialData={sectionData}
        isComplete={isComplete}
        supabaseUrl={supabaseUrl}
        supabaseAnonKey={supabaseAnonKey}
      />
    )}

    <!-- Section navigation -->
    <div class="flex items-center justify-between mt-10 pt-6 border-t border-border-light">
      {prevSection ? (
        <a href={`/intake/${prevSection.slug}`} class="font-sans text-xs text-mid-gray hover:text-charcoal transition-colors uppercase tracking-widest">
          &larr; {prevSection.title}
        </a>
      ) : <span />}
      {nextSection ? (
        <a href={`/intake/${nextSection.slug}`} class="font-sans text-xs text-mid-gray hover:text-charcoal transition-colors uppercase tracking-widest">
          {nextSection.title} &rarr;
        </a>
      ) : (
        <a href="/intake" class="btn-primary text-xs px-4 py-2">
          Back to Dashboard
        </a>
      )}
    </div>
  </div>
</IntakeLayout>
