---
export const prerender = false;

import IntakeLayout from '../../layouts/IntakeLayout.astro';
import { createClient } from '@supabase/supabase-js';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

// Handle sign out
if (Astro.request.method === 'POST') {
  const url = new URL(Astro.request.url);
  if (url.searchParams.get('action') === 'signout') {
    Astro.cookies.delete('sb-access-token', { path: '/' });
    Astro.cookies.delete('sb-refresh-token', { path: '/' });
    return new Response('OK', { status: 200 });
  }
}

// Handle auth callback (magic link redirect)
const url = new URL(Astro.request.url);
const code = url.searchParams.get('code');

if (code) {
  const supabase = createClient(supabaseUrl, supabaseAnonKey, {
    auth: { flowType: 'pkce', autoRefreshToken: false, detectSessionInUrl: false },
  });

  const { data, error } = await supabase.auth.exchangeCodeForSession(code);

  if (!error && data.session) {
    // Set auth cookies
    Astro.cookies.set('sb-access-token', data.session.access_token, {
      path: '/',
      httpOnly: true,
      secure: true,
      sameSite: 'lax',
      maxAge: 60 * 60,
    });
    Astro.cookies.set('sb-refresh-token', data.session.refresh_token!, {
      path: '/',
      httpOnly: true,
      secure: true,
      sameSite: 'lax',
      maxAge: 60 * 60 * 24 * 30,
    });

    // Create client record if first time
    const serviceRoleKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;
    if (serviceRoleKey) {
      const adminClient = createClient(supabaseUrl, serviceRoleKey, {
        auth: { autoRefreshToken: false, persistSession: false },
      });

      const { data: existing } = await adminClient
        .from('clients')
        .select('id')
        .eq('auth_user_id', data.session.user.id)
        .single();

      if (!existing) {
        await adminClient.from('clients').insert({
          auth_user_id: data.session.user.id,
          contact_email: data.session.user.email || '',
        });
      }
    }

    return Astro.redirect('/intake');
  }
}

// Check if already logged in
const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) {
  const supabase = createClient(supabaseUrl, supabaseAnonKey, {
    auth: { flowType: 'pkce', autoRefreshToken: false, detectSessionInUrl: false },
  });
  const { data: { user } } = await supabase.auth.getUser(accessToken);
  if (user) {
    return Astro.redirect('/intake');
  }
}
---

<IntakeLayout title="Sign In" showSignOut={false}>
  <div class="max-w-md mx-auto mt-12">
    <h1 class="section-subheading text-center mb-2">Your Workspace</h1>
    <p class="font-serif text-mid-gray text-center mb-8">
      Enter your email and we'll send you a login link. No password needed.
    </p>

    <div id="login-form">
      <div class="mb-4">
        <label for="email" class="form-label">Email Address</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="you@yourpractice.com"
          class="form-input w-full"
          required
        />
      </div>
      <button
        id="send-link-btn"
        type="button"
        class="btn-primary w-full"
      >
        Send me a login link
      </button>
    </div>

    <div id="success-message" class="hidden text-center">
      <div class="card bg-white">
        <p class="font-serif text-charcoal mb-2">Check your email.</p>
        <p class="font-serif text-mid-gray text-sm">
          We sent a login link to <strong id="sent-email" class="text-charcoal"></strong>.
          Click the link to access your workspace.
        </p>
      </div>
    </div>

    <div id="error-message" class="hidden text-center mt-4">
      <p class="font-sans text-sm text-red-600" id="error-text"></p>
    </div>
  </div>

  <script define:vars={{ supabaseUrl, supabaseAnonKey }}>
    const { createClient } = await import('https://esm.sh/@supabase/supabase-js@2');
    const supabase = createClient(supabaseUrl, supabaseAnonKey);

    const emailInput = document.getElementById('email');
    const sendBtn = document.getElementById('send-link-btn');
    const loginForm = document.getElementById('login-form');
    const successMsg = document.getElementById('success-message');
    const errorMsg = document.getElementById('error-message');
    const errorText = document.getElementById('error-text');
    const sentEmail = document.getElementById('sent-email');

    sendBtn.addEventListener('click', async () => {
      const email = emailInput.value.trim();
      if (!email) return;

      sendBtn.textContent = 'Sending...';
      sendBtn.disabled = true;
      errorMsg.classList.add('hidden');

      const { error } = await supabase.auth.signInWithOtp({
        email,
        options: {
          emailRedirectTo: `${window.location.origin}/intake/login`,
        },
      });

      if (error) {
        errorText.textContent = error.message;
        errorMsg.classList.remove('hidden');
        sendBtn.textContent = 'Send me a login link';
        sendBtn.disabled = false;
        return;
      }

      sentEmail.textContent = email;
      loginForm.classList.add('hidden');
      successMsg.classList.remove('hidden');
    });
  </script>
</IntakeLayout>
