---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureCard from '../components/FeatureCard.astro';
import FAQBlock from '../components/FAQBlock.astro';
import CTABlock from '../components/CTABlock.astro';

const faqs = [
  {
    question: 'How long does the build take?',
    answer: 'Give us your website URL and you\'ll have a live preview within 24 hours. After your feedback, the final site is typically ready in 3-7 business days.',
  },
  {
    question: 'What if I don\'t have a website yet?',
    answer: 'Even better. We\'ll build you one from scratch based on your practice info. Fill out the intake form and we\'ll handle the rest. Same price, same timeline.',
  },
  {
    question: 'Do I need to be technical?',
    answer: 'Not at all. We set up every account, configure every setting, and hand you documentation that explains what everything is. If you can send an email, you can manage your website.',
  },
  {
    question: 'What if I want changes after the build?',
    answer: 'If you\'re self-hosting, any developer can make changes — the code is standard, well-documented, and yours. If you\'re on managed hosting ($100/mo), content updates are included.',
  },
  {
    question: 'Is this just for dentists?',
    answer: 'Right now, yes. We\'re focused entirely on dental practices because specialization means better results. Every template, every schema type, every content structure is built specifically for how dental patients search and what Google expects from dental websites.',
  },
];
---

<BaseLayout
  title="How It Works — Custom Dental Websites in Days | Groundwork Dental"
  description="The problem with dental websites, what a proper one requires, and how we build yours in days. AI-optimized, SEO-ready, owned by you. $2,000 flat."
>
  <!-- Hero -->
  <section class="bg-brand-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="max-w-3xl">
        <p class="eyebrow text-brand-warm mb-4">How it works</p>
        <h1 class="section-heading mb-6">A Professional Dental Website. Without the Headache.</h1>
        <p class="font-serif text-xl text-mid-gray leading-relaxed">
          Most dental websites are slow, generic, and locked behind an agency you can't leave. Here's what we do differently — and why it matters for both Google and AI search.
        </p>
      </div>
    </div>
  </section>

  <!-- The Problem -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-subheading mb-8">The Problem with Most Dental Websites</h2>
      <div class="prose-article text-lg">
        <p>
          The typical dental website is a WordPress template shared with hundreds of other practices. It loads in 4-6 seconds on mobile. It has 10-15 pages of generic content that could apply to any dentist in the country. The agency charges $200-500/month to "host" it — but the hosting costs them $5/month.
        </p>
        <p>
          If you stop paying, the website vanishes. Sometimes they own your domain too. And the SEO? Basic meta tags at best. No structured data. No authority content. Google knows you exist, but it doesn't know what you do.
        </p>
        <p>
          Now add AI search to the mix. When a patient asks ChatGPT or Google's AI "who's a good implant dentist near me?" — these tools pull from websites with structured, authoritative content. A template WordPress site with generic copy doesn't give AI anything useful to work with. You're invisible in the fastest-growing search channel.
        </p>
      </div>
    </div>
  </section>

  <!-- What We Build -->
  <section class="py-16 bg-surface-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-subheading text-center mb-4">What a Proper Dental Website Needs</h2>
      <p class="font-serif text-mid-gray text-center mb-12 max-w-2xl mx-auto">
        These aren't nice-to-haves. These are baseline requirements for showing up in search — both traditional Google and AI-powered search tools.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <FeatureCard
          title="90+ PageSpeed"
          description="Google uses page speed as a ranking factor. Static HTML loads instantly. No WordPress plugins, no JavaScript frameworks, no bloated page builders."
        />
        <FeatureCard
          title="Structured Data for Google & AI"
          description="7+ schema types tell Google and AI tools exactly what you do, where you are, and what services you offer. This is how you show up in AI Overviews and ChatGPT responses."
        />
        <FeatureCard
          title="Authority Architecture"
          description="30-50+ pages organized into topic clusters. Implants hub, cosmetic hub, each with deep sub-pages. This depth signals expertise to both search engines and AI."
        />
        <FeatureCard
          title="Geographic Content"
          description="Location pages for your city and surrounding areas. When someone searches 'dentist in [nearby city],' you show up — even if you're technically in the next town over."
        />
        <FeatureCard
          title="Unique, Practice-Specific Content"
          description="Copy that mentions your specific practice, city, doctor, and services. Not generic text reused across hundreds of sites. Google penalizes duplicate medical content."
        />
        <FeatureCard
          title="Full Ownership"
          description="Your domain, your hosting, your code, your analytics. Fire us tomorrow — everything keeps working. No kill switch. No monthly hostage fee."
        />
      </div>
    </div>
  </section>

  <!-- AI SEO Section -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <p class="eyebrow text-brand-warm mb-4 text-center">The new search</p>
        <h2 class="section-subheading text-center mb-8">Showing Up in AI Search — Not Just Google</h2>
        <div class="prose-article text-lg">
          <p>
            Search is changing. Patients aren't just Googling "dentist near me" anymore. They're asking ChatGPT, Perplexity, Google AI Overviews, and Siri. These AI tools need to understand your practice to recommend it — and they pull that understanding from your website's structured data and content quality.
          </p>
          <p>
            A template WordPress site with generic copy gives AI nothing to work with. But a site with structured schema markup, authoritative content about specific procedures, and clear geographic information? That's exactly what these tools are looking for.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-8">
          <div class="card">
            <h3 class="font-serif text-charcoal mb-2">What AI search tools need</h3>
            <ul class="font-serif text-sm text-mid-gray space-y-1.5">
              <li>Schema markup (LocalBusiness, MedicalProcedure, Physician)</li>
              <li>Specific, factual content about your services</li>
              <li>Geographic specificity (city, address, service area)</li>
              <li>Doctor credentials and specialties</li>
              <li>Structured FAQ content with real answers</li>
            </ul>
          </div>
          <div class="card">
            <h3 class="font-serif text-charcoal mb-2">What most dental sites provide</h3>
            <ul class="font-serif text-sm text-mid-gray space-y-1.5">
              <li>No schema markup (or basic only)</li>
              <li>Generic copy reused across clients</li>
              <li>Vague service descriptions</li>
              <li>No doctor entity data</li>
              <li>No structured FAQ content</li>
            </ul>
          </div>
        </div>
        <p class="font-serif text-mid-gray mt-6 text-center text-sm">
          Every Groundwork site includes 7+ schema types, practice-specific content, and structured data on every page — the exact signals AI search tools use to recommend practices.
        </p>
      </div>
    </div>
  </section>

  <!-- The Process -->
  <section class="py-16 bg-surface-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-subheading text-center mb-12">The Process</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-10 h-10 rounded border border-border-light text-charcoal font-mono text-sm flex items-center justify-center mx-auto mb-4">01</div>
          <h3 class="font-serif text-charcoal mb-2">Give Us Your URL</h3>
          <p class="font-serif text-mid-gray text-sm leading-relaxed">Enter your current website URL. Within 24 hours, you'll have a live preview of your new site to click around.</p>
        </div>
        <div class="text-center">
          <div class="w-10 h-10 rounded border border-border-light text-charcoal font-mono text-sm flex items-center justify-center mx-auto mb-4">02</div>
          <h3 class="font-serif text-charcoal mb-2">Review & Refine</h3>
          <p class="font-serif text-mid-gray text-sm leading-relaxed">Check your phone. Read the content. Send us one round of feedback and we'll dial it in. No payment until you're happy.</p>
        </div>
        <div class="text-center">
          <div class="w-10 h-10 rounded border border-border-light text-charcoal font-mono text-sm flex items-center justify-center mx-auto mb-4">03</div>
          <h3 class="font-serif text-charcoal mb-2">Own It Forever</h3>
          <p class="font-serif text-mid-gray text-sm leading-relaxed">Pay $2,000. Everything transfers to your accounts. Code, hosting, domain, analytics. ~$12/year to keep it running.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Ownership vs Lock-in -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-subheading text-center mb-8">Ownership vs. Lock-In</h2>
      <div class="prose-article text-lg">
        <p>
          Most dental marketing agencies don't trap you on purpose. The lock-in is built into their business model. Your website lives on their server. They registered the domain in their name. The CMS is proprietary. If you leave, everything disappears.
        </p>
        <p>
          We do the opposite. Everything is in your name from day one — your domain registrar, your hosting account, your code repository, your Google accounts. We get collaborator access so we can work on your site, but you're the owner. Revoke our access anytime. Nothing changes.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-8 text-sm">
        <div class="card border-l-4 border-l-red-300">
          <h3 class="font-serif text-charcoal mb-3">Typical agency</h3>
          <ul class="font-serif text-mid-gray space-y-1.5">
            <li>Domain in agency's name</li>
            <li>Site on agency's server</li>
            <li>Proprietary CMS — can't export</li>
            <li>$200-500/month to keep it running</li>
            <li>Stop paying → site disappears</li>
          </ul>
        </div>
        <div class="card border-l-4 border-l-sage">
          <h3 class="font-serif text-charcoal mb-3">Groundwork</h3>
          <ul class="font-serif text-mid-gray space-y-1.5">
            <li>Domain in your name</li>
            <li>Site on your hosting (free)</li>
            <li>Standard code — any dev can edit</li>
            <li>$0/month (or $100 optional managed)</li>
            <li>Stop paying → nothing changes</li>
          </ul>
        </div>
      </div>
      <p class="font-serif text-sm text-mid-gray mt-6 text-center">
        Want to understand the traps in detail? Read our full guide: <a href="/why-agencies-lock-you-in" class="text-brand-warm hover:text-brand-warm-dark">Why Agencies Lock You In →</a>
      </p>
    </div>
  </section>

  <!-- The SEO Foundation -->
  <section class="py-16 bg-charcoal text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-serif text-3xl font-normal mb-6">The SEO Foundation You Get</h2>
        <p class="font-serif text-neutral-300 text-lg leading-relaxed mb-8">
          Every build includes the complete baseline for Google search, AI search, and local discovery. Not "Phase 2." Not "SEO is extra." This is what's included in the $2,000.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-left max-w-xl mx-auto text-sm">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-warm flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-neutral-200">Keyword-optimized titles on every page</span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-warm flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-neutral-200">7+ schema types per page</span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-warm flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-neutral-200">Google Business Profile optimization</span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-warm flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-neutral-200">XML sitemap submitted to Google</span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-warm flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-neutral-200">Internal linking across all pages</span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-warm flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-neutral-200">AI search optimization</span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-warm flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-neutral-200">Authority blog articles per service</span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-warm flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-neutral-200">Location pages for nearby cities</span>
          </div>
        </div>
        <p class="mt-8 text-sm text-neutral-400">
          Want the full deep dive? Read our <a href="/dental-seo-foundation" class="text-brand-warm hover:text-brand-warm-dark">complete SEO guide →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock
        heading="Ready to See Your Practice Reimagined?"
        subheading="Enter your website URL. We'll build a preview in 24 hours. No payment, no obligation."
        primaryCTA="Get Started"
        primaryHref="/get-started"
        secondaryCTA="See an example first"
        secondaryHref="/example"
        variant="warm"
      />
    </div>
  </section>
</BaseLayout>
