---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import FAQBlock from '../components/FAQBlock.astro';
import CTABlock from '../components/CTABlock.astro';
import { site } from '../config/site';

const comparisonRows = [
  { feature: 'Setup cost', diy: 'Free to start', traditional: '$2,000+', groundwork: '$2,000 flat' },
  { feature: 'Monthly fee', diy: 'Free (with their branding/ads) or $17+/mo', traditional: '$200+/mo required', groundwork: '$0 self-host (recommended)' },
  { feature: 'Ongoing cost (yearly)', diy: '$200+/year', traditional: '$2,400+/year', groundwork: '~$12\u201315/year (domain renewal)' },
  { feature: 'Pages', diy: '5\u201310 (you build them)', traditional: '10\u201320', groundwork: '30\u201350+' },
  { feature: 'Design', diy: 'Shared with millions', traditional: 'Shared across clients', groundwork: '100% custom to your practice' },
  { feature: 'SEO', diy: 'Basic/DIY', traditional: 'Basic', groundwork: 'Full \u2014 structured for Google + AI' },
  { feature: 'Ownership', diy: 'Platform controls hosting', traditional: 'Agency controls everything', groundwork: 'You own code, hosting, domain' },
  { feature: 'If you leave', diy: 'Export is limited/messy', traditional: 'Site disappears', groundwork: 'Nothing changes' },
  { feature: 'Build time', diy: 'Weeks of your own time', traditional: '6\u201312 weeks', groundwork: '3\u20137 business days' },
  { feature: 'Speed', diy: 'Slow\u2013moderate', traditional: 'Slow\u2013moderate', groundwork: 'Fast (90+ PageSpeed)' },
  { feature: 'GBP + Facebook', diy: 'Not included', traditional: 'Sometimes, extra cost', groundwork: 'Included' },
];

const faqs = [
  {
    question: 'How long does the build take?',
    answer: 'Give us your website URL and you\'ll have a live preview within 24 hours. After your feedback, the final site is typically ready in 3-7 business days.',
  },
  {
    question: 'What if I don\'t have a website yet?',
    answer: 'Even better. We\'ll build you one from scratch based on your practice info. Fill out the intake form and we\'ll handle the rest. Same price, same timeline.',
  },
  {
    question: 'Do I need to be technical?',
    answer: 'Not at all. We set up every account, configure every setting, and hand you documentation that explains what everything is. If you can send an email, you can manage your website.',
  },
  {
    question: 'What if I want changes after the build?',
    answer: 'If you\'re self-hosting, any developer can make changes \u2014 the code is standard, well-documented, and yours. If you\'re on managed hosting ($100/mo), content updates are included.',
  },
  {
    question: 'Is this just for dentists?',
    answer: 'Right now, yes. We\'re focused entirely on dental practices because specialization means better results. Every template, every schema type, every content structure is built specifically for how dental patients search and what Google expects from dental websites.',
  },
];
---

<BaseLayout
  title="How It Works — Custom Dental Websites in Days | Groundwork Dental"
  description="A modern dental website + optimized Google presence. One flat price. You own everything. No templates. No monthly fees. No fine print. Live in days."
>
  <!-- Hero -->
  <section class="bg-brand-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
      <div class="max-w-3xl">
        <p class="eyebrow text-brand-warm mb-4">How it works</p>
        <h1 class="section-heading mb-6">Your Practice Deserves a Better Online Presence.</h1>
        <p class="font-serif text-xl text-mid-gray leading-relaxed">
          A modern dental website + optimized Google presence. One flat price. You own everything. No templates. No monthly fees. No fine print. Live in days.
        </p>
      </div>
    </div>
  </section>

  <!-- The Problem -->
  <section class="py-10">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-subheading mb-8">The Problem</h2>
      <div class="prose-article text-lg">
        <p>
          Most dental practices are paying $300+/month for a website that was built once, rarely updated, and would disappear tomorrow if they stopped paying. The site is slow, templated, and shared with hundreds of other dentists. Dentists deserve better. Something modern, fast, and built right &mdash; without a monthly bill for a site that nobody's touching.
        </p>
        <p>
          Meanwhile, your Google Business Profile &mdash; the single biggest factor in whether patients find you on Google &mdash; is either incomplete or neglected. Your Facebook page is an afterthought. The two things that actually matter most for local search are the two things nobody's paying attention to.
        </p>
      </div>
    </div>
  </section>

  <!-- What This Service Is -->
  <section class="py-10 bg-surface-2">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-subheading mb-8">What This Service Is</h2>
      <div class="prose-article text-lg">
        <p>
          For most dental practices, this is all you need. A fast, modern website that patients and search engines both love, paired with a fully optimized Google Business Profile. Done right, this combination is the difference between showing up when someone searches "dentist near me" and not existing online at all.
        </p>
        <p>
          We're not a marketing agency. We don't run ads. We don't promise patient growth. What we build is the foundation that makes everything else possible &mdash; and the part that most practices are currently getting wrong or overpaying for.
        </p>
        <p>
          If down the road you want more &mdash; content marketing, competitive SEO, paid campaigns, a full rebrand &mdash; this foundation supports all of it. Build on it yourself, hire us for ongoing work, or hand it to any developer or agency. Nothing we build locks you in or limits what comes next. But for most practices, the groundwork is the thing that's missing. Start here.
        </p>
      </div>
    </div>
  </section>

  <!-- What We Deliver -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-subheading text-center mb-4">What We Deliver</h2>
      <p class="font-serif text-mid-gray text-center mb-12 max-w-2xl mx-auto">
        These aren't nice-to-haves. These are baseline requirements for showing up in search &mdash; both traditional Google and AI-powered search tools.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <FeatureCard
          title="Custom Website — Built Around Your Services"
          description="Every service category gets its own dedicated page with real, detailed content. A page that says 'We offer dental implants' tells Google nothing. A page that explains the procedure, who it's for, and what makes your approach different — that's what ranks."
        />
        <FeatureCard
          title="Structured Data for Google & AI"
          description="7+ schema types tell Google and AI tools exactly what you do, where you are, and what services you offer. This is how you show up in AI Overviews, ChatGPT responses, and Perplexity — not just search results, but actual citations."
        />
        <FeatureCard
          title="Google Business Profile Optimization"
          description="Your GBP is how most patients find you. Full audit and optimization: correct categories, complete service listings, photos, Q&A, review strategy, and consistent info across Google, Yelp, Apple Maps, and Bing Places."
        />
        <FeatureCard
          title="Facebook Page Optimization"
          description="Professional page setup, service listings, call-to-action buttons, review integration, and branded cover images. Not a social media strategy — just making sure the page looks right and works when patients land on it."
        />
        <FeatureCard
          title="90+ PageSpeed & Mobile-First"
          description="Static HTML loads instantly. No WordPress plugins, no JavaScript frameworks, no bloated page builders. Built mobile-first because that's how patients are searching."
        />
        <FeatureCard
          title="Full Ownership"
          description="Your domain, your hosting, your code, your analytics. Fire us tomorrow — everything keeps working. No kill switch. No monthly hostage fee. Hand it to any developer or agency."
        />
      </div>
    </div>
  </section>

  <!-- AI SEO Section -->
  <section class="py-10 bg-surface-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <p class="eyebrow text-brand-warm mb-4 text-center">The new search</p>
        <h2 class="section-subheading text-center mb-8">Showing Up in AI Search — Not Just Google</h2>
        <div class="prose-article text-lg">
          <p>
            Search is changing. Patients aren't just Googling "dentist near me" anymore. They're asking ChatGPT, Perplexity, Google AI Overviews, and Siri. These AI tools need to understand your practice to recommend it — and they pull that understanding from your website's structured data and content quality.
          </p>
          <p>
            A template WordPress site with generic copy gives AI nothing to work with. But a site with structured schema markup, authoritative content about specific procedures, and clear geographic information? That's exactly what these tools are looking for.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-8">
          <div class="card">
            <h3 class="font-serif text-charcoal mb-2">What AI search tools need</h3>
            <ul class="font-serif text-sm text-mid-gray space-y-1.5">
              <li>Schema markup (LocalBusiness, MedicalProcedure, Physician)</li>
              <li>Specific, factual content about your services</li>
              <li>Geographic specificity (city, address, service area)</li>
              <li>Doctor credentials and specialties</li>
              <li>Structured FAQ content with real answers</li>
            </ul>
          </div>
          <div class="card">
            <h3 class="font-serif text-charcoal mb-2">What most dental sites provide</h3>
            <ul class="font-serif text-sm text-mid-gray space-y-1.5">
              <li>No schema markup (or basic only)</li>
              <li>Generic copy reused across clients</li>
              <li>Vague service descriptions</li>
              <li>No doctor entity data</li>
              <li>No structured FAQ content</li>
            </ul>
          </div>
        </div>
        <p class="font-serif text-mid-gray mt-6 text-center text-sm">
          Every Groundwork site includes 7+ schema types, practice-specific content, and structured data on every page — the exact signals AI search tools use to recommend practices.
        </p>
      </div>
    </div>
  </section>

  <!-- A Note on SEO -->
  <section class="py-10">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-subheading mb-8">A Note on SEO</h2>
      <div class="prose-article text-lg">
        <p>
          What we deliver is a complete SEO foundation &mdash; the technical setup, page structure, and optimized content that puts your site in the best possible position to rank. Think of it as building a house on solid ground: the structure is sound, the wiring is right, and everything is up to code. This alone makes you more visible than the vast majority of dental websites running on slow templates with thin content.
        </p>
        <p>
          Going further &mdash; ranking for competitive treatment keywords, building authority in your market, climbing to the top of search results in a crowded area &mdash; that requires ongoing content: targeted articles published consistently over time. That's a conversation for after the foundation is built. This service is focused on getting the groundwork right first.
        </p>
        <p class="text-sm text-mid-gray">
          Want the full deep dive on dental SEO? Read our <a href="/dental-seo-foundation" class="text-brand-warm hover:text-brand-warm-dark">complete SEO guide &rarr;</a>
        </p>
      </div>
    </div>
  </section>

  <!-- How We Compare -->
  <section class="py-10 bg-surface-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <ComparisonTable rows={comparisonRows} heading="How We Compare" />
      <div class="max-w-3xl mx-auto mt-8">
        <div class="card">
          <p class="font-serif text-sm text-mid-gray leading-relaxed">
            <strong class="text-charcoal">A note on DIY platforms:</strong> Tools like Wix and Squarespace can be free or cheap to start — but you're the one building the site. That means writing all the content, structuring it for search engines, figuring out which services need their own pages, handling SEO settings, and learning a drag-and-drop editor that still won't give you structured data or the kind of page architecture that Google rewards. A dentist's time is worth $200+/hour — the math doesn't work. The "free" option has a real cost — it's just measured in your time instead of dollars.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- The Ownership Guarantee -->
  <section class="py-10">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-subheading text-center mb-8">The Ownership Guarantee</h2>
      <p class="font-serif text-mid-gray text-center mb-8">
        When the project is complete, we hand you everything:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-2xl mx-auto text-sm">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-sage flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="font-serif text-charcoal"><strong>Your website code</strong> — in a GitHub repository under your own account</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-sage flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="font-serif text-charcoal"><strong>Your hosting</strong> — a Cloudflare Pages account in your name</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-sage flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="font-serif text-charcoal"><strong>Your domain</strong> — registered under your name</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-sage flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="font-serif text-charcoal"><strong>Google Analytics & Search Console</strong> — under your Google account</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-sage flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="font-serif text-charcoal"><strong>Google Business Profile</strong> — optimized and under your login</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-sage flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="font-serif text-charcoal"><strong>Facebook page</strong> — optimized and under your admin access</span>
        </div>
        <div class="flex items-start gap-3 sm:col-span-2">
          <svg class="w-5 h-5 text-sage flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="font-serif text-charcoal"><strong>All content, design, and assets</strong> — every word, every image, every page. Yours.</span>
        </div>
      </div>
      <p class="font-serif text-mid-gray text-center text-sm mt-8">
        There's no second invoice. No credentials we keep. No login we hold onto. If you never talk to us again, everything keeps running exactly as it was. Hand it to another developer, another agency, or your tech-savvy nephew. It all transfers because it was always yours to begin with.
      </p>
    </div>
  </section>

  <!-- The Process -->
  <section class="py-10 bg-surface-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-subheading text-center mb-12">The Process</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-10 h-10 rounded border border-border-light text-charcoal font-mono text-sm flex items-center justify-center mx-auto mb-4">01</div>
          <h3 class="font-serif text-charcoal mb-2">Give Us Your URL</h3>
          <p class="font-serif text-mid-gray text-sm leading-relaxed">Enter your current website URL. Within 24 hours, you'll have a live preview of your new site to click around.</p>
        </div>
        <div class="text-center">
          <div class="w-10 h-10 rounded border border-border-light text-charcoal font-mono text-sm flex items-center justify-center mx-auto mb-4">02</div>
          <h3 class="font-serif text-charcoal mb-2">Review & Refine</h3>
          <p class="font-serif text-mid-gray text-sm leading-relaxed">Check your phone. Read the content. Send us one round of feedback and we'll dial it in. No payment until you're happy.</p>
        </div>
        <div class="text-center">
          <div class="w-10 h-10 rounded border border-border-light text-charcoal font-mono text-sm flex items-center justify-center mx-auto mb-4">03</div>
          <h3 class="font-serif text-charcoal mb-2">Own It Forever</h3>
          <p class="font-serif text-mid-gray text-sm leading-relaxed">Pay $2,000. Everything transfers to your accounts. Code, hosting, domain, analytics. ~$12/year to keep it running.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Summary -->
  <section class="py-10 bg-charcoal text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-serif text-3xl font-normal mb-8">Pricing</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
          <div>
            <p class="text-4xl text-brand-warm font-mono mb-2">$2,000</p>
            <p class="font-sans text-xs text-neutral-400 uppercase tracking-wider mb-3">One-time &mdash; Website + GBP + Facebook</p>
            <p class="font-serif text-neutral-300 text-sm leading-relaxed">
              Everything described on this page. Custom website, Google Business Profile optimization, Facebook page optimization, all accounts set up and transferred to you. ~$12/year after that for your domain.
            </p>
          </div>
          <div>
            <p class="text-4xl text-neutral-500 font-mono mb-2">$100<span class="text-lg">/mo</span></p>
            <p class="font-sans text-xs text-neutral-400 uppercase tracking-wider mb-3">Optional Managed Hosting</p>
            <p class="font-serif text-neutral-300 text-sm leading-relaxed">
              I do not recommend this — and I intentionally priced it high to discourage you. Your hosting is free after the build. The only recurring cost is ~$12/year for your domain. Only if you truly want a completely hands-off experience should you consider it.
            </p>
          </div>
        </div>
        <a href="/pricing" class="inline-block mt-8 btn-primary px-8 py-3.5">View Full Pricing</a>
      </div>
    </div>
  </section>

  <!-- What We Need From You -->
  <section class="py-10">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-subheading text-center mb-4">What We Need From You to Get Started</h2>
      <p class="font-serif text-mid-gray text-center mb-8">
        Most of this you already have &mdash; it's just a matter of gathering it in one place.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
        <div class="card">
          <h3 class="font-serif text-charcoal mb-1">Practice basics</h3>
          <p class="font-serif text-mid-gray">Name, address, phone, hours, and your current website URL if you have one.</p>
        </div>
        <div class="card">
          <h3 class="font-serif text-charcoal mb-1">Doctor info</h3>
          <p class="font-serif text-mid-gray">Name(s), credentials, specialty, and a short bio or CV we can work from.</p>
        </div>
        <div class="card">
          <h3 class="font-serif text-charcoal mb-1">Services</h3>
          <p class="font-serif text-mid-gray">A list of what you offer, and anything about how you talk about your work with patients. We'll write all the content.</p>
        </div>
        <div class="card">
          <h3 class="font-serif text-charcoal mb-1">Photos</h3>
          <p class="font-serif text-mid-gray">Exterior, interior, team, and treatment rooms. iPhone photos are fine &mdash; we'll send you a shot list.</p>
        </div>
        <div class="card">
          <h3 class="font-serif text-charcoal mb-1">Branding</h3>
          <p class="font-serif text-mid-gray">Logo files if you have them. If not, we can design one.</p>
        </div>
        <div class="card">
          <h3 class="font-serif text-charcoal mb-1">Digital accounts</h3>
          <p class="font-serif text-mid-gray">Google Business Profile login, Facebook page admin access, and any other social profiles.</p>
        </div>
        <div class="card sm:col-span-2">
          <h3 class="font-serif text-charcoal mb-1">Insurance & financing</h3>
          <p class="font-serif text-mid-gray">Whether you accept insurance, and any financing options you offer (Cherry, etc.) so we can build those pages out.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-10 bg-surface-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock
        heading="Ready to See Your Practice Reimagined?"
        subheading="Enter your website URL. We'll build a preview in 24 hours. No payment, no obligation."
        primaryCTA="Get Started"
        primaryHref="/get-started"
        secondaryCTA="See an example first"
        secondaryHref="/example"
        variant="warm"
      />
    </div>
  </section>
</BaseLayout>
